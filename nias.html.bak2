      L.polygon(z.ll, { color: z.color, fillColor: z.color, fillOpacity: 0.28, weight: 1 })
        .bindPopup(`<div style="font-family:monospace;font-size:12px;color:#050e1a"><b>${z.label}</b>${z.extra||''}</div>`)
