  { cls: 'lf-danger', msg: 'Solo exposto pós-colheita +38% acima média — MT Norte' },
  { cls: 'lf-sat',    msg: 'SMAP atualizado — umidade solo 0-10cm mapeada' },
  { cls: 'lf-warn',   msg: 'Preço tomate CEASA SP subiu 4.2% — oferta reduzida' },
  { cls: 'lf-ok',     msg: 'Modelo LSTM reprocessou fenologia — precisão +0.3%' },
  { cls: 'lf-danger', msg: 'Soja 2ª janela: δ_fenol caiu 0.012 — maturação antecipada' },
  { cls: 'lf-sat',    msg: 'Landsat-9 — cobertura Sul do Brasil atualizada' },
  { cls: 'lf-ok',     msg: 'AIS Marítimo: 3 graneleiros entrando em Santos' },
  { cls: 'lf-warn',   msg: 'Umidade solo Oeste Bahia: 18% — abaixo do limiar' },
];
let feedIdx = 0;
function pushFeedEvent() {
  const list = document.getElementById('live-feed-list');
  if (!list) return;
  const e = feedEvents[feedIdx % feedEvents.length];
  feedIdx++;
  const now = new Date().toLocaleTimeString('pt-BR');
  const div = document.createElement('div');
  div.className = 'lf-item';
  div.innerHTML = `<span class="${e.cls}">${e.msg}</span><br><span class="lf-time">${now}</span>`;
  list.insertBefore(div, list.firstChild);
  while (list.children.length > 40) list.removeChild(list.lastChild);
}
setInterval(pushFeedEvent, 2500);
pushFeedEvent(); pushFeedEvent(); pushFeedEvent(); pushFeedEvent(); pushFeedEvent();

