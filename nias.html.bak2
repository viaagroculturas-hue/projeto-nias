        <!-- POLO D: FRONTEIRA NORTE -->
        <div style="background:var(--bg2);border:1px solid #9b59b640;border-radius:6px;display:flex;flex-direction:column;overflow:hidden;">
          <div style="background:rgba(155,89,182,.10);padding:6px 10px;border-bottom:1px solid #9b59b630;display:flex;align-items:center;gap:8px;flex-shrink:0;">
            <span style="background:#9b59b6;color:#fff;font-weight:bold;font-size:10px;padding:2px 7px;border-radius:3px;">D</span>
            <span style="color:#9b59b6;font-size:10px;letter-spacing:1px;font-weight:bold;">FRONTEIRA NORTE — Agrofloresta + Conformidade</span>
            <span id="poleD-badge" style="margin-left:auto;font-size:9px;color:#9b59b6;border:1px solid #9b59b6;padding:1px 5px;border-radius:2px;">CAR: MONITORANDO</span>
          </div>
          <div style="flex:1;display:flex;overflow:hidden;">
            <div style="flex:1;padding:6px;overflow-y:auto;border-right:1px solid var(--border);">
              <div style="font-size:9px;color:var(--text2);letter-spacing:1px;margin-bottom:4px;">MUNICÍPIOS-CHAVE · DESMAT. + CAR</div>
              <table style="width:100%;border-collapse:collapse;" id="poleD-table"></table>
            </div>
            <div style="width:160px;padding:5px;display:flex;flex-direction:column;gap:3px;flex-shrink:0;">
              <div style="font-size:9px;color:var(--text2);letter-spacing:1px;">ALERTAS IA</div>
