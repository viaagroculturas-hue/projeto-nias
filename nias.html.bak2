// ── Rm calculation
function calcRm(mun) {
  const prodBase = { soja:3.4, milho:5.8, tomate:62, horti:28, cana:85, uva:18, maca:22, pastagem:1.2 };
  const base = prodBase[mun.culture] || 3.0;
  return +(mun.areaMha * 1000 * mun.ndvi * mun.coef * base / 1000).toFixed(2);
}

// ── Anomaly event templates (municipality-tagged)
const ANOMALY_EVENTS = [
  z => ({ cls:'lf-danger', msg:`[${z.name.toUpperCase()}-${z.state}] Quebra de ${(Math.random()*3+0.5).toFixed(1)}% no talhão Norte. Causa: Estresse hídrico localizado. NDVI: ${z.ndvi.toFixed(2)}` }),
  z => ({ cls:'lf-warn',   msg:`[${z.name.toUpperCase()}-${z.state}] NDVI caiu ${(Math.random()*0.08+0.03).toFixed(2)} em 7 dias. Correlacionando fenologia (${Math.round(z.ndvi*130)}d ciclo)...` }),
  z => ({ cls:'lf-ok',     msg:`[${z.name.toUpperCase()}-${z.state}] Motor fenológico: PRÉ-COLHEITA detectada. Solo exposto +${(Math.random()*20+8).toFixed(0)}% vs média histórica.` }),
  z => ({ cls:'lf-sat',    msg:`[${z.name.toUpperCase()}-${z.state}] Sentinel-2 atualizado: ${(z.areaMha*10).toFixed(0)} polígonos recalculados. Rm = ${calcRm(z)} kt` }),
  z => ({ cls:'lf-warn',   msg:`[${z.name.toUpperCase()}-${z.state}] Amplitude térmica ΔT: ${(Math.random()*6+6).toFixed(1)}°C. ${z.culture==='tomate'?'Risco BRIX ↓':'Ciclo fenológico ajustado'}.` }),
  z => ({ cls:'lf-danger', msg:`[${z.name.toUpperCase()}-${z.state}] Irrigação ${(Math.random()*30+10).toFixed(0)}% acima da média histórica. Monitorar salinização do solo.` }),
  z => ({ cls:'lf-ok',     msg:`[${z.name.toUpperCase()}-${z.state}] Safra ${z.culture} antecipada em ${Math.round(Math.random()*5+2)} dias. Solo exposto em expansão via SAR.` }),
  z => ({ cls:'lf-danger', msg:`[${z.name.toUpperCase()}-${z.state}] Risco de ${Math.random()<0.5?'geada':'granizo'} em 48h. Proteção de lavoura recomendada.` }),
  z => ({ cls:'lf-warn',   msg:`[${z.name.toUpperCase()}-${z.state}] Gargalo logístico: terminal mais próximo com ${(Math.random()*20+55).toFixed(0)}% de ocupação. Retenção estimada: ${(Math.random()*300+50).toFixed(0)}t.` }),
  z => ({ cls:'lf-ok',     msg:`[${z.name.toUpperCase()}-${z.state}] NDVI ${z.ndvi.toFixed(2)} — produção no percentil ${Math.round(Math.random()*25+70)}° vs histórico. Safra acima da média.` }),
];

let munMap, munLayerGroup;
let activePolygons = {};

function initMunicipal() {
  window._munInit = true;
  munMap = L.map('map-municipal', { center: [-15, -55], zoom: 4, zoomControl: true });
  L.tileLayer('https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png',
    { attribution:'© CartoDB', maxZoom:18 }).addTo(munMap);

  munLayerGroup = L.layerGroup().addTo(munMap);
  // Local DB polygons as supplementary layer (detailed pins)
  renderChoropleth('all');
  buildMunTable('all');
  startAnomalyRadar();
  populateSimMun();
  setTimeout(addCrossBorderVectors, 800);
  // IBGE drill-down system (state choropleth loads on top)
  setTimeout(initStateChoropleth, 200);
}

function renderChoropleth(cultureFilter) {
  munLayerGroup.clearLayers();
  activePolygons = {};
  const countryFilter = document.getElementById('mun-country')?.value || 'all';
  const filtered = MUNICIPAL_DB.filter(m =>
    (cultureFilter === 'all' || m.culture === cultureFilter) &&
    (countryFilter === 'all' || m.country === countryFilter)
  );
  filtered.forEach(mun => {
    const fillColor = cultureColor(mun.culture, mun.ndvi, 0.78);
    const borderColor = cultureColor(mun.culture, Math.min(0.85, mun.ndvi + 0.15), 1.0);
    const poly = L.polygon(mun.poly, {
      color: borderColor,
      fillColor,
      fillOpacity: 0.72,
      weight: 1.2,
    });
    const rm = calcRm(mun);
    const adminLabel = { BR:'Município/IBGE', AR:'Departamento/INDEC', PY:'Distrito/DGEEC', UY:'Seção/INE' }[mun.country] || 'Unidade';
    poly.bindPopup(`
      <div style="font-family:monospace;font-size:12px;min-width:200px;">
        <b style="color:#050e1a;font-size:13px;">${mun.name}</b>
        <div style="color:#333;font-size:10px;">${adminLabel} — ${mun.state} · ${mun.country}</div>
        <hr style="border-color:#ccc;margin:4px 0;">
        <div><b>Cultura:</b> ${mun.culture.toUpperCase()}</div>
        <div><b>Área:</b> ${(mun.areaMha*1000).toFixed(0)} kha</div>
        <div><b>NDVI:</b> ${mun.ndvi.toFixed(3)} <span style="color:${mun.ndvi<0.50?'red':mun.ndvi<0.60?'orange':'green'}">${mun.ndvi<0.50?'▼ ALERTA':mun.ndvi<0.60?'▼ ATENÇÃO':'✓ NORMAL'}</span></div>
        <div><b>Coef. Manejo:</b> ${mun.coef.toFixed(2)}</div>
        <div style="margin-top:4px;background:#eee;padding:3px 5px;border-radius:3px;"><b>Rm = ${rm} kt</b></div>
      </div>
    `);
    poly.on('click', () => highlightMunicipal(mun.id));
    poly.addTo(munLayerGroup);
    activePolygons[mun.id] = { poly, mun };
  });
}

function filterMunicipalMap(cultureFilter) {
  renderChoropleth(cultureFilter);
  buildMunTable(cultureFilter);
}

function highlightMunicipal(id) {
  const entry = activePolygons[id];
  if (!entry) return;
  // Flash highlight
  entry.poly.setStyle({ weight: 3, fillOpacity: 0.95 });
  setTimeout(() => entry.poly.setStyle({ weight: 1.2, fillOpacity: 0.72 }), 1500);
}

function buildMunTable(cultureFilter) {
  const tbody = document.getElementById('mun-table-body');
  if (!tbody) return;
  const countryFilter = document.getElementById('mun-country')?.value || 'all';
  const filtered = MUNICIPAL_DB.filter(m =>
    (cultureFilter === 'all' || m.culture === cultureFilter) &&
    (countryFilter === 'all' || m.country === countryFilter)
  ).sort((a,b) => calcRm(b) - calcRm(a));

  tbody.innerHTML = filtered.map(m => {
    const rm = calcRm(m);
    const ndviColor = m.ndvi < 0.45 ? 'var(--danger)' : m.ndvi < 0.58 ? 'var(--warn)' : 'var(--accent2)';
    const status = m.ndvi < 0.45 ? '<span style="color:var(--danger);font-size:9px;">CRÍTICO</span>'
                 : m.ndvi < 0.55 ? '<span style="color:var(--warn);font-size:9px;">ATENÇÃO</span>'
                 : '<span style="color:var(--accent2);font-size:9px;">NORMAL</span>';
    const flag = { BR:'🇧🇷', AR:'🇦🇷', PY:'🇵🇾', UY:'🇺🇾' }[m.country] || '';
    return `<tr style="cursor:pointer;" onclick="highlightMunicipal('${m.id}')">
      <td style="padding:5px 8px;border-bottom:1px solid var(--border);font-size:10px;">${flag} ${m.name}<span style="color:var(--text2);font-size:9px;"> · ${m.state}</span></td>
      <td style="padding:5px 8px;border-bottom:1px solid var(--border);font-size:10px;color:var(--text2);">${m.culture}</td>
      <td style="padding:5px 8px;border-bottom:1px solid var(--border);font-size:10px;text-align:right;color:${ndviColor};" id="mun-ndvi-${m.id}">${m.ndvi.toFixed(3)}</td>
      <td style="padding:5px 8px;border-bottom:1px solid var(--border);font-size:10px;text-align:right;color:var(--accent);font-weight:bold;" id="mun-rm-${m.id}">${rm}</td>
      <td style="padding:5px 8px;border-bottom:1px solid var(--border);text-align:center;">${status}</td>
    </tr>`;
  }).join('');
}

// ── Live NDVI update on municipal polygons
function updateMunicipalNdvi() {
  MUNICIPAL_DB.forEach(m => {
    // micro-fluctuation per municipality (independent microclimate)
    m.ndvi = Math.max(0.20, Math.min(0.82, m.ndvi + (Math.random() - 0.502) * 0.006));
    // update table cell
    const el = document.getElementById('mun-ndvi-' + m.id);
    if (el) { el.textContent = m.ndvi.toFixed(3); el.style.color = m.ndvi < 0.45 ? 'var(--danger)' : m.ndvi < 0.58 ? 'var(--warn)' : 'var(--accent2)'; }
    const rmEl = document.getElementById('mun-rm-' + m.id);
    if (rmEl) rmEl.textContent = calcRm(m);
    // update polygon fill
    const entry = activePolygons[m.id];
    if (entry) {
      entry.poly.setStyle({
        fillColor: cultureColor(m.culture, m.ndvi, 0.78),
        color: cultureColor(m.culture, Math.min(0.85, m.ndvi + 0.15), 1.0),
      });
    }
  });
}
setInterval(updateMunicipalNdvi, 7000);

// ── Anomaly Radar — municipality-tagged precision feed
let anomalyIdx = 0;
function startAnomalyRadar() {
  // seed 6 initial events
  for (let i = 0; i < 6; i++) pushAnomalyEvent();
}
function pushAnomalyEvent() {
  const list = document.getElementById('anomaly-radar-list');
  if (!list) return;
  const mun = MUNICIPAL_DB[anomalyIdx % MUNICIPAL_DB.length];
  anomalyIdx++;
  const tmpl = ANOMALY_EVENTS[Math.floor(Math.random() * ANOMALY_EVENTS.length)];
  const { cls, msg } = tmpl(mun);
  const now = new Date();
  const ts = now.toLocaleTimeString('pt-BR', { hour:'2-digit', minute:'2-digit', second:'2-digit' });
  const div = document.createElement('div');
  div.className = 'lf-item';
  div.style.borderLeft = `2px solid ${cls==='lf-danger'?'var(--danger)':cls==='lf-warn'?'var(--warn)':cls==='lf-ok'?'var(--accent2)':'var(--accent)'}`;
  div.style.paddingLeft = '8px';
  div.innerHTML = `<span class="${cls}" style="font-size:10px;">${msg}</span><br><span class="lf-time">${ts} · ${{'BR':'Brasil','AR':'Argentina','PY':'Paraguai','UY':'Uruguai'}[mun.country]}</span>`;
  list.insertBefore(div, list.firstChild);
  while (list.children.length > 60) list.removeChild(list.lastChild);
}
setInterval(() => window.pushAnomalyEvent && window.pushAnomalyEvent(), 2800);

