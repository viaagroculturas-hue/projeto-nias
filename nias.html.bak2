<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>NIA$ — Núcleo de Inteligência Agro-Sul</title>
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<style>
:root {
  --bg:#050e1a;--bg2:#091422;--bg3:#0d1f33;--border:#0e2d4a;
  --accent:#00d4ff;--accent2:#00ff88;--accent3:#ff6b35;
  --warn:#ffc107;--danger:#ff3d3d;--text:#c8dff0;--text2:#6a92b0;
  --font:'Courier New',monospace;
}

/* ── LIGHT MODE ── */
[data-theme='light'] {
  --bg:#f0f4f8;--bg2:#e4ecf4;--bg3:#d8e4ef;--border:#b0c4d8;
  --accent:#1565c0;--accent2:#1b7a3e;--accent3:#c0440a;
  --warn:#9a6600;--danger:#b51010;--text:#1a2a3a;--text2:#4a6a84;
}
[data-theme='light'] body { background:var(--bg); }
[data-theme='light'] #map,
[data-theme='light'] #map-municipal { filter:brightness(1.15) saturate(1.1); }
[data-theme='light'] .panel-header { background:#d0dded; }
[data-theme='light'] #topbar { background:#dde8f0; }
[data-theme='light'] #price-ticker { background:#c8d8e8; }
[data-theme='light'] .nav-sidebar { background:#cad8e8;border-right-color:#b0c4d8; }
[data-theme='light'] .route-card { background:#e4ecf4;border-color:#b0c4d8; }
[data-theme='light'] #arb-strip { background:#ecf2f8; }

/* ── CYBER AI MODE ── */
[data-theme='cyber'] {
  --bg:#000000;--bg2:#010608;--bg3:#020d04;--border:#003010;
  --accent:#ff003c;--accent2:#00ff00;--accent3:#ff6600;
  --warn:#ffff00;--danger:#ff0000;--text:#00ff00;--text2:#007700;
}
[data-theme='cyber'] body { background:#000; }
[data-theme='cyber'] body::after {
  content:'';position:fixed;inset:0;
  background:repeating-linear-gradient(0deg,transparent,transparent 3px,rgba(0,255,0,.04) 3px,rgba(0,255,0,.04) 4px);
  pointer-events:none;z-index:9998;
  animation:scanlines 12s linear infinite;
}
@keyframes scanlines { 0%{background-position:0 0} 100%{background-position:0 200%} }
[data-theme='cyber'] #map,
[data-theme='cyber'] #map-municipal { filter:hue-rotate(100deg) saturate(2.5) brightness(0.8) contrast(1.2); }
[data-theme='cyber'] .panel-header { background:#000;border-bottom-color:#003010; }
[data-theme='cyber'] #topbar { background:#000;border-bottom-color:#003010; }
[data-theme='cyber'] #price-ticker { background:#000; }
[data-theme='cyber'] .logo { color:#ff003c; text-shadow:0 0 12px #ff003c; }
[data-theme='cyber'] .logo span { color:#00ff00; }

/* Cyber arbitrage ticker animations */
[data-theme='cyber'] .arb-opp {
  color:#00ff00 !important;
  animation:cyberGreen 1.2s ease-in-out infinite;
}
[data-theme='cyber'] .arb-risk {
  color:#ff0000 !important;
  animation:cyberRed 0.9s ease-in-out infinite;
}
[data-theme='cyber'] .arb-hold {
  color:#ffff00 !important;
  animation:cyberYellow 1.5s ease-in-out infinite;
}
@keyframes cyberGreen {
  0%,100%{text-shadow:0 0 6px #00ff00;} 50%{text-shadow:0 0 18px #00ff00,0 0 30px #00a000;}
}
@keyframes cyberRed {
  0%,100%{text-shadow:0 0 6px #ff0000;opacity:1;} 50%{text-shadow:0 0 20px #ff0000,0 0 35px #aa0000;opacity:.85;}
}
@keyframes cyberYellow {
  0%,100%{text-shadow:0 0 5px #ffff00;} 50%{text-shadow:0 0 16px #ffff00;}
}
[data-theme='cyber'] #arb-strip {
  border-top-color:#003010;
  background:rgba(0,20,0,.6);
}
[data-theme='cyber'] #arb-strip table thead th {
  color:#ff003c !important;
  border-bottom:1px solid #003010;
}
[data-theme='cyber'] .route-card { background:#010a02;border-color:#003010; }
[data-theme='cyber'] .nav-btn { border-color:#003010; }
[data-theme='cyber'] .nav-btn:hover { background:rgba(0,255,0,.06); }
[data-theme='cyber'] .nav-btn.active { background:rgba(0,255,0,.1);border-left-color:#00ff00; }

/* Theme toggle buttons */
.theme-toggle { display:flex;align-items:center;gap:4px;margin-left:auto;flex-shrink:0; }
.theme-btn {
  background:none;border:1px solid var(--border);color:var(--text2);
  font-family:var(--font);font-size:11px;padding:4px 8px;border-radius:4px;
  cursor:pointer;transition:all .2s;white-space:nowrap;
}
.theme-btn:hover { border-color:var(--accent);color:var(--accent); }
.theme-btn.active { background:rgba(0,212,255,.12);border-color:var(--accent);color:var(--accent); }
*{margin:0;padding:0;box-sizing:border-box;}
body{background:var(--bg);color:var(--text);font-family:var(--font);font-size:13px;overflow:hidden;height:100vh;}

/* TOP BAR */
#topbar{height:48px;background:var(--bg2);border-bottom:1px solid var(--border);display:flex;align-items:center;padding:0 16px;gap:14px;position:relative;z-index:1000;flex-shrink:0;}
.logo{color:var(--accent);font-size:15px;font-weight:bold;letter-spacing:3px;white-space:nowrap;}
.logo span{color:var(--accent2);}
.top-meta{color:var(--text2);font-size:11px;white-space:nowrap;}
.pulse{display:inline-block;width:8px;height:8px;border-radius:50%;background:var(--accent2);animation:pulse 1.5s infinite;flex-shrink:0;}
@keyframes pulse{0%,100%{opacity:1;box-shadow:0 0 0 0 rgba(0,255,136,.6)}50%{opacity:.8;box-shadow:0 0 0 6px rgba(0,255,136,0)}}
.top-stats{display:flex;gap:20px;margin-left:auto;}
.top-stat{text-align:center;cursor:default;}
.top-stat .val{font-size:13px;font-weight:bold;transition:color .3s;}
.top-stat .lbl{color:var(--text2);font-size:9px;letter-spacing:1px;}
.val-flash{animation:flash .4s ease;}
@keyframes flash{0%,100%{opacity:1}50%{opacity:.3}}

/* PRICE TICKER */
#price-ticker{height:24px;background:#020a14;border-bottom:1px solid var(--border);display:flex;align-items:center;overflow:hidden;flex-shrink:0;}
.ticker-inner{display:flex;gap:40px;animation:ticker-scroll 50s linear infinite;white-space:nowrap;}
@keyframes ticker-scroll{0%{transform:translateX(100vw)}100%{transform:translateX(-300%)}}
.tick-item{font-size:11px;display:flex;gap:6px;}
.tick-name{color:var(--text2);}
.tick-val{font-weight:bold;}
.tick-up{color:var(--accent2);}
.tick-dn{color:var(--danger);}

/* LAYOUT */
#app{display:flex;height:calc(100vh - 72px);}
#sidebar{width:56px;background:var(--bg2);border-right:1px solid var(--border);display:flex;flex-direction:column;align-items:center;padding:12px 0;gap:6px;transition:width .3s;flex-shrink:0;}
#sidebar.expanded{width:180px;}
.nav-btn{width:40px;height:38px;border-radius:8px;border:1px solid transparent;background:none;cursor:pointer;display:flex;align-items:center;justify-content:center;color:var(--text2);font-size:16px;transition:all .2s;flex-shrink:0;}
.nav-btn:hover,.nav-btn.active{background:rgba(0,212,255,.1);border-color:var(--accent);color:var(--accent);}
.nav-label{display:none;font-size:11px;margin-left:8px;white-space:nowrap;}
#sidebar.expanded .nav-btn{width:160px;justify-content:flex-start;padding-left:12px;}
#sidebar.expanded .nav-label{display:inline;}
.nav-divider{width:32px;height:1px;background:var(--border);margin:2px 0;}
#main{flex:1;overflow:hidden;position:relative;display:flex;flex-direction:column;}
.panel{display:none;width:100%;flex:1;flex-direction:column;overflow:hidden;}
.panel.active{display:flex;}

/* PANEL HEADER */
.panel-header{height:38px;background:var(--bg2);border-bottom:1px solid var(--border);display:flex;align-items:center;padding:0 14px;gap:10px;flex-shrink:0;}
.panel-title{color:var(--accent);font-size:11px;font-weight:bold;letter-spacing:2px;}
.panel-badge{background:rgba(0,212,255,.15);border:1px solid var(--accent);color:var(--accent);font-size:10px;padding:2px 7px;border-radius:3px;white-space:nowrap;}
.panel-badge.warn{background:rgba(255,193,7,.1);border-color:var(--warn);color:var(--warn);}
.panel-badge.danger{background:rgba(255,61,61,.1);border-color:var(--danger);color:var(--danger);}
.panel-badge.ok{background:rgba(0,255,136,.1);border-color:var(--accent2);color:var(--accent2);}
.badge-live{background:rgba(255,61,61,.15);border:1px solid var(--danger);color:var(--danger);font-size:10px;padding:2px 7px;border-radius:3px;animation:blink-badge 1s infinite;}
.lyr-btn{background:none;border:1px solid var(--border);color:var(--text2);font-family:var(--font);font-size:9px;padding:2px 8px;border-radius:3px;cursor:pointer;white-space:nowrap;transition:all .15s;}
.lyr-btn.active{background:rgba(0,212,255,.12);border-color:var(--accent);color:var(--accent);}
.lyr-btn:hover{border-color:var(--accent);color:var(--accent);}
@keyframes risk-pulse{0%,100%{opacity:1;transform:scale(1)}50%{opacity:.4;transform:scale(1.5)}}
.risk-pulse-marker{animation:risk-pulse 2s ease-in-out infinite;}
.cult-btn{display:block;width:100%;text-align:left;background:none;border:1px solid var(--border);color:var(--text2);font-family:var(--font);font-size:10px;padding:3px 7px;border-radius:3px;cursor:pointer;margin-bottom:3px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;transition:all .12s;}
.cult-btn:hover{background:rgba(0,212,255,.08);border-color:var(--accent);color:var(--accent);}
.cult-btn.active{background:rgba(0,212,255,.15);border-color:var(--accent);color:var(--accent);font-weight:bold;}
@keyframes neon-pulse{0%,100%{box-shadow:0 0 4px #00ff88,0 0 8px #00ff88}50%{box-shadow:0 0 10px #00ff88,0 0 20px #00ff88}}
.top10-neon path{animation:neon-pulse 1.5s ease-in-out infinite;}
@keyframes blink-badge{0%,100%{opacity:1}50%{opacity:.5}}

/* ALERTS STRIP */
#alerts-strip{height:28px;background:rgba(255,61,61,.07);border-bottom:1px solid rgba(255,61,61,.25);display:flex;align-items:center;overflow:hidden;flex-shrink:0;}
.alert-scroll{display:flex;gap:32px;animation:scroll-left 35s linear infinite;white-space:nowrap;}
@keyframes scroll-left{0%{transform:translateX(100vw)}100%{transform:translateX(-200%)}}
.alert-item{color:var(--danger);font-size:11px;}
.alert-item .sep{color:var(--text2);margin:0 8px;}

/* KPI ROW */
.kpi-row{display:flex;border-bottom:1px solid var(--border);flex-shrink:0;}
.kpi-card{flex:1;padding:10px 14px;border-right:1px solid var(--border);position:relative;overflow:hidden;}
.kpi-card:last-child{border-right:none;}
.kpi-label{font-size:9px;color:var(--text2);letter-spacing:1px;margin-bottom:2px;}
.kpi-value{font-size:20px;font-weight:bold;color:var(--accent);transition:color .3s;}
.kpi-delta{font-size:10px;margin-top:2px;}
.kpi-delta.up{color:var(--accent2);}
.kpi-delta.down{color:var(--danger);}
.kpi-delta.neu{color:var(--warn);}
.kpi-spark{position:absolute;bottom:0;left:0;right:0;height:30px;opacity:.4;}

/* OVERVIEW BOTTOM */
.overview-bottom{flex:1;display:flex;overflow:hidden;}
.ov-alerts{width:310px;border-right:1px solid var(--border);display:flex;flex-direction:column;overflow:hidden;flex-shrink:0;}
.ov-alerts-title{padding:8px 14px;color:var(--accent);font-size:10px;letter-spacing:2px;border-bottom:1px solid var(--border);flex-shrink:0;display:flex;justify-content:space-between;align-items:center;}
.ov-alerts-list{flex:1;overflow-y:auto;}
.alert-card{padding:10px 14px;border-bottom:1px solid var(--border);cursor:pointer;transition:background .2s;}
.alert-card:hover{background:rgba(0,212,255,.04);}
.alert-card-header{display:flex;justify-content:space-between;align-items:flex-start;gap:8px;}
.alert-card-title{font-size:11px;color:var(--text);font-weight:bold;}
.severity{font-size:9px;padding:2px 6px;border-radius:2px;white-space:nowrap;}
.severity.alta{background:rgba(255,61,61,.2);border:1px solid var(--danger);color:var(--danger);}
.severity.media{background:rgba(255,193,7,.15);border:1px solid var(--warn);color:var(--warn);}
.severity.baixa{background:rgba(0,255,136,.1);border:1px solid var(--accent2);color:var(--accent2);}
.alert-card-body{font-size:10px;color:var(--text2);margin-top:3px;line-height:1.5;}
.alert-time{font-size:9px;color:var(--text2);margin-top:3px;}

/* OVERVIEW RIGHT */
.ov-right{flex:1;display:flex;flex-direction:column;overflow:hidden;}
.ov-chart-area{flex:1;padding:10px 12px;display:flex;flex-direction:column;}
.ov-chart-title{font-size:10px;color:var(--accent);letter-spacing:2px;margin-bottom:6px;flex-shrink:0;}
.ov-chart-wrap{flex:1;position:relative;}

/* LIVE FEED */
.live-feed{width:280px;border-left:1px solid var(--border);display:flex;flex-direction:column;overflow:hidden;flex-shrink:0;}
.lf-title{padding:8px 12px;color:var(--accent);font-size:10px;letter-spacing:2px;border-bottom:1px solid var(--border);flex-shrink:0;display:flex;align-items:center;gap:6px;}
.lf-list{flex:1;overflow-y:auto;padding:4px 0;}
.lf-item{padding:6px 12px;border-bottom:1px solid rgba(14,45,74,.5);font-size:10px;line-height:1.5;animation:fade-in .4s ease;}
@keyframes fade-in{from{opacity:0;transform:translateY(-4px)}to{opacity:1;transform:translateY(0)}}
.lf-time{color:var(--text2);font-size:9px;}
.lf-sat{color:var(--accent);}
.lf-warn{color:var(--warn);}
.lf-danger{color:var(--danger);}
.lf-ok{color:var(--accent2);}

/* WEATHER ROW */
.weather-row{height:54px;border-bottom:1px solid var(--border);display:flex;flex-shrink:0;overflow:hidden;}
.wx-card{flex:1;border-right:1px solid var(--border);padding:6px 12px;display:flex;flex-direction:column;justify-content:center;}
.wx-card:last-child{border-right:none;}
.wx-region{font-size:9px;color:var(--text2);letter-spacing:1px;}
.wx-vals{display:flex;gap:12px;margin-top:2px;align-items:baseline;}
.wx-temp{font-size:14px;font-weight:bold;color:var(--accent);}
.wx-hum{font-size:10px;color:var(--text2);}
.wx-wind{font-size:10px;color:var(--text2);}
.wx-status{font-size:9px;margin-top:1px;}

/* MAP */
#map-container{flex:1;position:relative;}
#map{width:100%;height:100%;}
.map-controls{position:absolute;top:10px;right:10px;z-index:999;background:rgba(5,14,26,.92);border:1px solid var(--border);border-radius:8px;padding:10px;display:flex;flex-direction:column;gap:6px;min-width:190px;}
.map-ctrl-title{color:var(--accent);font-size:10px;letter-spacing:2px;margin-bottom:3px;}
.layer-toggle{display:flex;align-items:center;gap:7px;cursor:pointer;}
.layer-toggle input{accent-color:var(--accent);}
.layer-toggle label{color:var(--text);font-size:11px;cursor:pointer;}
.legend-item{display:flex;align-items:center;gap:5px;margin-bottom:3px;}
.legend-dot{width:10px;height:10px;border-radius:2px;}
.legend-label{font-size:10px;color:var(--text2);}
.map-stats{position:absolute;bottom:10px;left:10px;z-index:999;background:rgba(5,14,26,.92);border:1px solid var(--border);border-radius:8px;padding:8px 12px;display:flex;flex-direction:column;gap:3px;}
.map-stats p{font-size:10px;color:var(--text2);}
.map-stats strong{color:var(--accent2);}
.map-sat-bar{position:absolute;top:10px;left:10px;z-index:999;background:rgba(5,14,26,.92);border:1px solid var(--border);border-radius:8px;padding:8px 12px;min-width:200px;}
.sat-title{color:var(--accent);font-size:10px;letter-spacing:1px;margin-bottom:6px;}
.sat-row{display:flex;justify-content:space-between;font-size:10px;margin-bottom:3px;}
.sat-name{color:var(--text2);}
.sat-val{color:var(--accent2);}
.sat-progress{height:3px;background:var(--border);border-radius:2px;margin-top:2px;overflow:hidden;}
.sat-fill{height:100%;background:var(--accent);border-radius:2px;transition:width 2s linear;}

/* LOGISTICA */
.log-left{flex:1;display:flex;flex-direction:column;padding:10px;border-right:1px solid var(--border);}
.log-right{width:280px;display:flex;flex-direction:column;overflow-y:auto;}
.sankey-wrap{flex:1;position:relative;}
.route-card{background:var(--bg3);border-left:3px solid var(--border);padding:8px 12px;transition:all .3s;}
.route-card:hover{border-left-color:var(--accent);}
.route-card.danger{border-left-color:var(--danger);}
.route-card.warn{border-left-color:var(--warn);}
.route-card.ok{border-left-color:var(--accent2);}
.route-name{font-size:11px;color:var(--text);font-weight:bold;}
.route-detail{font-size:10px;color:var(--text2);margin:1px 0;}
.progress-bar{height:4px;background:var(--border);border-radius:2px;margin-top:5px;overflow:hidden;}
.progress-fill{height:100%;border-radius:2px;transition:width 1s ease;}
.counter-row{display:flex;justify-content:space-between;margin-top:3px;}
.counter-val{font-size:11px;font-weight:bold;}

/* OFERTA */
.oferta-chart{flex:1;padding:10px;border-right:1px solid var(--border);display:flex;flex-direction:column;}
.oferta-table{width:320px;overflow-y:auto;}
table{width:100%;border-collapse:collapse;}
th{background:var(--bg3);color:var(--accent);font-size:10px;letter-spacing:1px;padding:7px 9px;text-align:left;position:sticky;top:0;}
td{padding:6px 9px;border-bottom:1px solid var(--border);font-size:11px;color:var(--text);transition:color .5s;}
tr:hover td{background:rgba(0,212,255,.04);}
.td-up{color:var(--accent2);}
.td-dn{color:var(--danger);}
.td-neu{color:var(--warn);}
.cell-title{color:var(--accent);font-size:10px;letter-spacing:2px;margin-bottom:6px;flex-shrink:0;}
.cell-subtitle{color:var(--text2);font-size:10px;margin-bottom:8px;flex-shrink:0;}
.chart-wrap{flex:1;position:relative;min-height:0;}

/* CHAT */
#panel-chat .content{flex:1;display:flex;overflow:hidden;}
.chat-area{flex:1;display:flex;flex-direction:column;border-right:1px solid var(--border);}
.chat-messages{flex:1;overflow-y:auto;padding:14px;display:flex;flex-direction:column;gap:10px;}
.msg{max-width:76%;display:flex;flex-direction:column;gap:3px;}
.msg.nias{align-self:flex-start;}
.msg.user{align-self:flex-end;}
.msg-bubble{padding:9px 13px;border-radius:12px;font-size:11px;line-height:1.65;border:1px solid var(--border);}
.msg.nias .msg-bubble{background:var(--bg3);border-color:var(--accent);color:var(--text);border-top-left-radius:2px;}
.msg.user .msg-bubble{background:rgba(0,212,255,.1);border-color:var(--accent);color:var(--text);border-top-right-radius:2px;}
.msg-meta{font-size:10px;color:var(--text2);}
.msg.user .msg-meta{text-align:right;}
.chat-input-area{padding:10px;border-top:1px solid var(--border);display:flex;gap:8px;flex-shrink:0;}
.chat-input{flex:1;background:var(--bg3);border:1px solid var(--border);border-radius:6px;padding:7px 11px;color:var(--text);font-family:var(--font);font-size:11px;outline:none;resize:none;}
.chat-input:focus{border-color:var(--accent);}
.btn-send{background:rgba(0,212,255,.15);border:1px solid var(--accent);color:var(--accent);padding:7px 14px;border-radius:6px;cursor:pointer;font-family:var(--font);font-size:11px;transition:all .2s;}
.btn-send:hover{background:rgba(0,212,255,.28);}
.chat-sidebar{width:260px;display:flex;flex-direction:column;padding:10px;gap:7px;overflow-y:auto;}
.chat-side-title{color:var(--accent);font-size:10px;letter-spacing:2px;flex-shrink:0;}
.quick-btn{background:var(--bg3);border:1px solid var(--border);color:var(--text2);text-align:left;padding:7px 11px;border-radius:6px;cursor:pointer;font-family:var(--font);font-size:11px;transition:all .2s;line-height:1.4;}
.quick-btn:hover{border-color:var(--accent);color:var(--text);}
.status-block{background:var(--bg3);border:1px solid var(--border);border-radius:6px;padding:9px;}
.status-row{display:flex;justify-content:space-between;align-items:center;margin-bottom:5px;}
.status-row:last-child{margin-bottom:0;}
.status-label{font-size:10px;color:var(--text2);}
.status-val{font-size:10px;}

/* SCROLLBAR */
::-webkit-scrollbar{width:4px;height:4px;}
::-webkit-scrollbar-track{background:var(--bg);}
::-webkit-scrollbar-thumb{background:var(--border);border-radius:2px;}
::-webkit-scrollbar-thumb:hover{background:var(--accent);}

/* TYPING */
.typing{display:flex;gap:4px;align-items:center;padding:3px 0;}
.typing span{width:5px;height:5px;background:var(--accent);border-radius:50%;animation:blink .8s infinite;}
.typing span:nth-child(2){animation-delay:.2s;}
.typing span:nth-child(3){animation-delay:.4s;}
@keyframes blink{0%,100%{opacity:.2}50%{opacity:1}}

/* SATELLITE COUNTER */
.sat-countdown{font-size:16px;font-weight:bold;color:var(--accent);letter-spacing:2px;}

/* HORTIFRUTIS SECTION */
#horti-section{border-bottom:1px solid var(--border);flex-shrink:0;}
.horti-header{height:30px;background:rgba(0,212,255,.04);border-bottom:1px solid var(--border);display:flex;align-items:center;padding:0 14px;gap:10px;}
.horti-title{color:var(--accent);font-size:10px;font-weight:bold;letter-spacing:2px;}
.horti-badge{font-size:9px;padding:2px 7px;border-radius:3px;}
.horti-badge.warn{background:rgba(255,193,7,.1);border:1px solid var(--warn);color:var(--warn);}
.horti-badge.danger{background:rgba(255,61,61,.08);border:1px solid var(--danger);color:var(--danger);}
.horti-grid{display:flex;overflow-x:auto;gap:0;}
.horti-grid::-webkit-scrollbar{height:3px;}
.horti-card{min-width:148px;flex-shrink:0;border-right:1px solid var(--border);padding:8px 10px;position:relative;overflow:hidden;cursor:default;transition:background .2s;}
.horti-card:hover{background:rgba(0,212,255,.04);}
.horti-card:last-child{border-right:none;}
.horti-spark{position:absolute;top:0;left:0;width:100%;height:36px;opacity:.18;pointer-events:none;}
.horti-icon{font-size:16px;line-height:1;margin-bottom:2px;position:relative;z-index:1;}
.horti-name{font-size:10px;font-weight:bold;color:var(--accent);letter-spacing:1px;position:relative;z-index:1;}
.horti-region{font-size:9px;color:var(--text2);margin-bottom:4px;position:relative;z-index:1;}
.horti-vol{font-size:14px;font-weight:bold;color:var(--text);position:relative;z-index:1;}
.horti-price{font-size:11px;color:var(--accent2);font-weight:bold;position:relative;z-index:1;transition:color .3s;}
.horti-delta{font-size:9px;margin-top:2px;position:relative;z-index:1;}
.horti-delta.danger{color:var(--danger);}
.horti-delta.ok{color:var(--accent2);}
.horti-ndvi{font-size:9px;color:var(--text2);margin-top:2px;position:relative;z-index:1;}
.horti-status{font-size:9px;margin-top:3px;padding:2px 5px;border-radius:2px;display:inline-block;position:relative;z-index:1;font-weight:bold;letter-spacing:1px;}
.horti-status.danger{background:rgba(255,61,61,.15);border:1px solid var(--danger);color:var(--danger);}
.horti-status.warn{background:rgba(255,193,7,.12);border:1px solid var(--warn);color:var(--warn);}
.horti-status.ok{background:rgba(0,255,136,.08);border:1px solid var(--accent2);color:var(--accent2);}
.horti-type-tag{font-size:8px;padding:2px 5px;border-radius:2px;display:inline-block;margin-bottom:3px;letter-spacing:.5px;font-weight:bold;}
.horti-subregion{font-size:9px;color:var(--text2);line-height:1.4;position:relative;z-index:1;}
.horti-card-mesa{border-top:2px solid var(--accent);}
.horti-card-ind{border-top:2px solid var(--accent3);}

/* ── NDVI PHENOLOGY ENGINE ── */
.ndvi-tag{font-size:9px;padding:2px 6px;border-radius:2px;display:inline-block;margin-top:2px;font-weight:bold;letter-spacing:.5px;}
.ndvi-tag.harvest{background:rgba(0,255,136,.12);border:1px solid var(--accent2);color:var(--accent2);}
.ndvi-tag.pest{background:rgba(255,61,61,.15);border:1px solid var(--danger);color:var(--danger);}
.ndvi-tag.drought{background:rgba(255,107,53,.15);border:1px solid var(--accent3);color:var(--accent3);}
.ndvi-tag.normal{background:rgba(0,212,255,.08);border:1px solid var(--accent);color:var(--accent);}
.phenol-bar-wrap{margin-top:4px;position:relative;z-index:1;}
.phenol-label{font-size:9px;color:var(--text2);display:flex;justify-content:space-between;}
.phenol-bar{height:3px;background:var(--border);border-radius:2px;margin-top:2px;overflow:hidden;}
.phenol-fill{height:100%;border-radius:2px;transition:width 1s ease;}

/* ── BRIX / ΔT INDICATOR ── */
.brix-panel{margin-top:5px;background:rgba(255,107,53,.06);border:1px solid rgba(255,107,53,.25);border-radius:4px;padding:5px 7px;position:relative;z-index:1;}
.brix-row{display:flex;justify-content:space-between;align-items:center;margin-bottom:2px;}
.brix-label{font-size:9px;color:var(--text2);}
.brix-val{font-size:11px;font-weight:bold;}
.brix-bar{height:4px;background:var(--border);border-radius:2px;margin-top:3px;overflow:hidden;}
.brix-fill{height:100%;border-radius:2px;transition:width 1s ease;}
.delta-t-row{display:flex;justify-content:space-between;align-items:center;margin-top:3px;}
.delta-t-warn{color:var(--danger);font-size:9px;font-weight:bold;}
.delta-t-ok{color:var(--accent2);font-size:9px;font-weight:bold;}

/* ── LOGISTICS SPEED METER ── */
.speed-meter{margin-top:4px;padding:5px 8px;background:rgba(0,0,0,.2);border-radius:4px;}
.speed-row{display:flex;justify-content:space-between;align-items:center;font-size:10px;margin-bottom:2px;}
.speed-label{color:var(--text2);}
.speed-val{font-weight:bold;}
.speed-bar{height:3px;background:var(--border);border-radius:2px;overflow:hidden;}
.speed-fill{height:100%;border-radius:2px;transition:width 1.2s ease;}

/* ── FAIL-SAFE STATUS BAR ── */
#failsafe-bar{height:22px;background:rgba(0,212,255,.04);border-bottom:1px solid var(--border);display:flex;align-items:center;padding:0 14px;gap:16px;flex-shrink:0;font-size:9px;}
.fs-item{display:flex;align-items:center;gap:4px;color:var(--text2);}
.fs-dot{width:6px;height:6px;border-radius:50%;flex-shrink:0;}
.fs-active{color:var(--accent2);}
.fs-warn{color:var(--warn);}
.fs-danger{color:var(--danger);}

/* ── CLOUD COVER ── */
.sar-badge{background:rgba(155,89,182,.15);border:1px solid #9b59b6;color:#9b59b6;font-size:9px;padding:1px 5px;border-radius:2px;animation:blink-badge .8s infinite;}

/* ══════════════════════════════════════════════════════════════
   RBAC — LOGIN OVERLAY
══════════════════════════════════════════════════════════════ */
#nias-login-overlay {
  position:fixed;inset:0;z-index:99999;
  display:flex;align-items:center;justify-content:center;
  background:#000;
  overflow:hidden;
}
#nias-login-overlay .login-bg-canvas {
  position:absolute;inset:0;z-index:0;
}
#nias-login-overlay .login-card {
  position:relative;z-index:2;
  background:rgba(5,14,26,.72);
  border:1px solid rgba(80,200,120,.35);
  border-radius:16px;
  padding:48px 52px 40px;
  width:380px;
  box-shadow:0 0 80px rgba(80,200,120,.18), 0 0 200px rgba(0,212,255,.06), inset 0 0 30px rgba(0,0,0,.5);
  backdrop-filter:blur(18px) saturate(1.4);
  -webkit-backdrop-filter:blur(18px) saturate(1.4);
  text-align:center;
}
#nias-login-overlay .login-logo {
  font-family:'Courier New',monospace;
  font-size:2.4rem;font-weight:bold;letter-spacing:4px;
  color:#50c878;
  text-shadow:0 0 18px #50c878, 0 0 40px rgba(80,200,120,.4);
  margin-bottom:4px;
}
#nias-login-overlay .login-logo span { color:#00d4ff; }
#nias-login-overlay .login-sub {
  font-family:'Courier New',monospace;font-size:10px;
  letter-spacing:3px;color:rgba(80,200,120,.65);margin-bottom:32px;
}
#nias-login-overlay .login-label {
  font-family:'Courier New',monospace;font-size:10px;
  letter-spacing:2px;color:rgba(200,223,240,.55);
  text-align:left;margin-bottom:6px;display:block;
}
#nias-login-overlay .login-input {
  width:100%;box-sizing:border-box;
  background:rgba(0,212,255,.06);
  border:1px solid rgba(80,200,120,.4);
  border-radius:6px;padding:11px 14px;
  font-family:'Courier New',monospace;font-size:13px;
  color:#c8dff0;outline:none;letter-spacing:2px;
  transition:border-color .25s,box-shadow .25s;margin-bottom:18px;
}
#nias-login-overlay .login-input:focus {
  border-color:#50c878;
  box-shadow:0 0 10px rgba(80,200,120,.35);
}
#nias-login-overlay .login-btn-primary {
  width:100%;padding:12px;border:none;border-radius:7px;
  background:linear-gradient(135deg,#50c878,#00d4ff);
  color:#050e1a;font-family:'Courier New',monospace;
  font-size:12px;font-weight:bold;letter-spacing:2px;cursor:pointer;
  margin-bottom:10px;
  box-shadow:0 0 20px rgba(80,200,120,.4);
  transition:opacity .2s,transform .1s;
}
#nias-login-overlay .login-btn-primary:hover { opacity:.88;transform:scale(1.01); }
#nias-login-overlay .login-btn-guest {
  width:100%;padding:10px;border:1px solid rgba(80,200,120,.35);
  border-radius:7px;background:transparent;
  color:#50c878;font-family:'Courier New',monospace;
  font-size:11px;letter-spacing:2px;cursor:pointer;
  transition:background .2s,box-shadow .2s;
}
#nias-login-overlay .login-btn-guest:hover {
  background:rgba(80,200,120,.09);
  box-shadow:0 0 10px rgba(80,200,120,.18);
}
#nias-login-overlay .login-error {
  font-family:'Courier New',monospace;font-size:10px;
  color:#ff3d3d;letter-spacing:1px;min-height:16px;margin-bottom:10px;
  text-shadow:0 0 6px #ff3d3d;
}
#nias-login-overlay .login-badge-row {
  margin-top:22px;display:flex;gap:8px;justify-content:center;
}
#nias-login-overlay .login-badge {
  font-family:'Courier New',monospace;font-size:8px;letter-spacing:1px;
  border-radius:3px;padding:3px 8px;
  color:rgba(200,223,240,.4);border:1px solid rgba(200,223,240,.15);
}

/* Guest restriction overlays */
.rbac-locked {
  position:relative;pointer-events:none;user-select:none;
}
.rbac-locked::after {
  content:'🔒 APENAS PREMIUM';
  position:absolute;inset:0;
  background:rgba(5,14,26,.78);
  backdrop-filter:blur(4px);
  display:flex;align-items:center;justify-content:center;
  font-family:'Courier New',monospace;font-size:11px;letter-spacing:2px;
  color:#50c878;border-radius:inherit;z-index:10;
}
.rbac-blur { filter:blur(5px) !important; pointer-events:none; }
.rbac-premium-btn {
  background:rgba(80,200,120,.1) !important;
  border:1px solid #50c878 !important;
  color:#50c878 !important;cursor:default !important;
}
</style>
</head>
<body>

<!-- ══════════════════════════════════════════════════════════════
     NIA$ LOGIN OVERLAY
══════════════════════════════════════════════════════════════ -->
<div id="nias-login-overlay">
  <canvas class="login-bg-canvas" id="login-canvas"></canvas>
  <div class="login-card">
    <div class="login-logo">N<span>IA</span>$</div>
    <div class="login-sub">BIO-PRECISION · GEOSPATIAL AI</div>

    <label class="login-label">CÓDIGO DE ACESSO</label>
    <input type="password" id="login-code" class="login-input" placeholder="••••••••" autocomplete="off"
           onkeydown="if(event.key==='Enter')_niasLogin()" />
    <div class="login-error" id="login-err"></div>

    <button class="login-btn-primary" onclick="_niasLogin()">▶ ACESSAR SISTEMA</button>
    <button class="login-btn-guest" onclick="_niasGuestLogin()">👁 ACESSO TEMPORÁRIO DE CONVIDADO</button>

    <div class="login-badge-row">
      <span class="login-badge">🛰 SENTINEL-2</span>
      <span class="login-badge">📡 SAR ACTIVE</span>
      <span class="login-badge">⬡ RBAC v2</span>
    </div>
  </div>
</div>

<!-- TOP BAR -->
<div id="topbar">
  <span class="logo">N<span>IA</span>$</span>
  <span class="pulse"></span>
  <span class="top-meta" id="clock"></span>
  <div style="width:1px;height:24px;background:var(--border);flex-shrink:0;"></div>
  <div class="top-stats">
    <div class="top-stat" title="Cobertura orbital ativa"><div class="val" id="ts-cob" style="color:var(--accent2)">98.7%</div><div class="lbl">COBERTURA</div></div>
    <div class="top-stat" title="Alertas ativos"><div class="val" id="ts-alr" style="color:var(--danger)">4</div><div class="lbl">ALERTAS</div></div>
    <div class="top-stat" title="NDVI médio Cerrado"><div class="val" id="ts-ndvi" style="color:var(--accent)">0.610</div><div class="lbl">NDVI CER.</div></div>
    <div class="top-stat" title="Umidade média do solo"><div class="val" id="ts-hum" style="color:var(--accent)">34.0%</div><div class="lbl">UMID. SOLO</div></div>
    <div class="top-stat" title="Saturação BR-163"><div class="val" id="ts-br163" style="color:var(--danger)">82%</div><div class="lbl">BR-163</div></div>
    <div class="top-stat" title="Próximo passe orbital"><div class="val" id="ts-orbit" style="color:var(--warn)">--:--</div><div class="lbl">PASSE SAT.</div></div>
    <div class="top-stat" title="Veículos detectados hoje"><div class="val" id="ts-trucks" style="color:var(--accent)">3.240</div><div class="lbl">VEÍC/DIA</div></div>
    <div class="top-stat" title="Temperatura média MATOPIBA"><div class="val" id="ts-temp" style="color:var(--warn)">36.2°C</div><div class="lbl">MATOPIBA</div></div>
  </div>
  <div style="width:1px;height:24px;background:var(--border);flex-shrink:0;margin-left:8px;"></div>
  <div class="theme-toggle">
    <button id="theme-btn-dark"  class="theme-btn active" onclick="setTheme('dark')"  title="Dark Mode — Salas de Situação">🌑 DARK</button>
    <button id="theme-btn-light" class="theme-btn"        onclick="setTheme('light')" title="Light Mode — Campo / Escritório">☀ LIGHT</button>
    <button id="theme-btn-cyber" class="theme-btn"        onclick="setTheme('cyber')" title="Cyber AI — Apresentações Executivas">⬡ CYBER</button>
  </div>
</div>

<!-- PRICE TICKER -->
<div id="price-ticker">
  <div class="ticker-inner" id="ticker-inner">
    <span class="tick-item"><span class="tick-name">SOJA (CBOT)</span><span class="tick-val tick-dn" id="tp-soja">US$ 10.42/bu ▼</span></span>
    <span class="tick-item"><span class="tick-name">MILHO (CBOT)</span><span class="tick-val tick-up" id="tp-milho">US$ 4.68/bu ▲</span></span>
    <span class="tick-item"><span class="tick-name">BOI GORDO (B3)</span><span class="tick-val tick-up" id="tp-boi">R$ 312.40/@  ▲</span></span>
    <span class="tick-item"><span class="tick-name">AÇÚCAR (ICE)</span><span class="tick-val tick-dn" id="tp-acucar">US$ 19.85/lb ▼</span></span>
    <span class="tick-item"><span class="tick-name">CAFÉ ARÁBICA</span><span class="tick-val tick-up" id="tp-cafe">US$ 218.60/sc ▲</span></span>
    <span class="tick-item"><span class="tick-name">ALGODÃO (ICE)</span><span class="tick-val tick-dn" id="tp-algodao">US$ 72.30/lb ▼</span></span>
    <span class="tick-item"><span class="tick-name">USD/BRL</span><span class="tick-val tick-up" id="tp-usd">R$ 5.124 ▲</span></span>
    <span class="tick-item"><span class="tick-name">TOMATE SP CEASA</span><span class="tick-val tick-up" id="tp-tomate">R$ 68.20/cx ▲</span></span>
  </div>
</div>

<!-- FAIL-SAFE STATUS BAR -->
<div id="failsafe-bar">
  <span class="fs-item fs-active"><span class="fs-dot" style="background:var(--accent2)"></span>FENOLOGIA ENGINE</span>
  <span class="fs-item" id="fs-sar"><span class="fs-dot" style="background:var(--accent2)"></span>SAR AUTO: <span id="fs-sar-val" style="color:var(--accent2);margin-left:3px;">STANDBY</span></span>
  <span class="fs-item"><span class="fs-dot" style="background:var(--accent2)"></span>NUVENS: <span id="fs-cloud" style="color:var(--accent2);margin-left:3px;">18%</span></span>
  <span class="fs-item"><span class="fs-dot" style="background:var(--accent2)"></span>CEPEA API: <span id="fs-cepea" style="color:var(--accent2);margin-left:3px;">ATIVO · 14:32</span></span>
  <span class="fs-item"><span class="fs-dot" id="fs-gps-dot" style="background:var(--warn)"></span>GPS FROTAS: <span id="fs-gps" style="color:var(--warn);margin-left:3px;">LATÊNCIA 3min</span></span>
  <span class="fs-item"><span class="fs-dot" style="background:var(--accent2)"></span>VECTOR TILES: <span id="fs-tiles" style="color:var(--accent2);margin-left:3px;">ATIVO</span></span>
  <span class="fs-item"><span class="fs-dot" style="background:var(--accent2)"></span>FALLBACK PREÇO: <span id="fs-fallback" style="color:var(--accent2);margin-left:3px;">NÃO ATIVADO</span></span>
  <span class="fs-item" style="margin-left:auto;"><span id="fs-engine-cycles" style="color:var(--text2);">Ciclos processados: <strong id="fs-cycles" style="color:var(--accent)">0</strong></span></span>
</div>

<!-- APP -->
<div id="app">

  <!-- SIDEBAR -->
  <div id="sidebar">
    <button class="nav-btn active" onclick="showPanel('overview')" title="Visão Geral"><span>⬡</span><span class="nav-label">VISÃO GERAL</span></button>
    <button class="nav-btn" onclick="showPanel('map')" title="Mapa Geo-IA"><span>◈</span><span class="nav-label">MAPA GEO-IA</span></button>
    <button class="nav-btn" onclick="showPanel('logistica')" title="Logística"><span>⟳</span><span class="nav-label">LOGÍSTICA</span></button>
    <button class="nav-btn" onclick="showPanel('oferta')" title="Oferta e Preços"><span>≋</span><span class="nav-label">OFERTA / PREÇOS</span></button>
    <button class="nav-btn" onclick="showPanel('municipal')" title="Análise Municipal"><span>⬢</span><span class="nav-label">ANÁLISE MUNICIPAL</span></button>
    <button class="nav-btn" onclick="showPanel('macropolos')" title="Macro-Polos Continental"><span>✦</span><span class="nav-label">MACRO-POLOS</span></button>
    <div class="nav-divider"></div>
    <button class="nav-btn" onclick="showPanel('chat')" title="Assistente IA"><span>◉</span><span class="nav-label">ASSISTENTE IA</span></button>
    <div style="flex:1"></div>
    <button class="nav-btn" onclick="toggleSidebar()" title="Expandir"><span id="sb-icon">»</span></button>
  </div>

  <!-- MAIN -->
  <div id="main">

    <!-- ═══ PANEL: OVERVIEW ═══ -->
    <div class="panel active" id="panel-overview">
      <div class="panel-header">
        <span class="panel-title">STATUS GERAL — AMÉRICA DO SUL</span>
        <span class="panel-badge ok">SISTEMA OPERACIONAL</span>
        <span class="panel-badge warn" id="ph-delta">δ_clima = 0.968</span>
        <span class="panel-badge danger" id="ph-alerts">4 ALERTAS ATIVOS</span>
        <span class="badge-live">● LIVE</span>
      </div>
      <div id="alerts-strip">
        <div class="alert-scroll">
          <span class="alert-item">⚠ ESTRESSE HÍDRICO — Oeste da Bahia / Norte MT<span class="sep">|</span></span>
          <span class="alert-item">⚠ SUSPEITA DE PRAGA — Norte PR / Sul MS<span class="sep">|</span></span>
          <span class="alert-item">⚠ GARGALO LOGÍSTICO — BR-163 / Porto Santos 82%<span class="sep">|</span></span>
          <span class="alert-item">⚠ ANOMALIA TÉRMICA — Cinturão Verde SP/MG/PR +2.1°C<span class="sep">|</span></span>
          <span class="alert-item">⚠ ESTRESSE HÍDRICO — Oeste da Bahia / Norte MT</span>
        </div>
      </div>

      <!-- WEATHER ROW -->
      <div class="weather-row">
        <div class="wx-card"><div class="wx-region">MATOPIBA (BA/PI/TO)</div><div class="wx-vals"><span class="wx-temp" id="wx-t1">36.2°C</span><span class="wx-hum" id="wx-h1">Umid: 18%</span><span class="wx-wind" id="wx-w1">Vento: 14km/h</span></div><div class="wx-status" id="wx-s1" style="color:var(--danger)">⚠ SECO / ESTRESSE</div></div>
        <div class="wx-card"><div class="wx-region">CERRADO (MT/GO)</div><div class="wx-vals"><span class="wx-temp" id="wx-t2">33.8°C</span><span class="wx-hum" id="wx-h2">Umid: 31%</span><span class="wx-wind" id="wx-w2">Vento: 9km/h</span></div><div class="wx-status" id="wx-s2" style="color:var(--warn)">↓ UMIDADE EM DECLÍNIO</div></div>
        <div class="wx-card"><div class="wx-region">NORTE PR / SUL MS</div><div class="wx-vals"><span class="wx-temp" id="wx-t3">28.4°C</span><span class="wx-hum" id="wx-h3">Umid: 68%</span><span class="wx-wind" id="wx-w3">Vento: 11km/h</span></div><div class="wx-status" id="wx-s3" style="color:var(--warn)">⚠ COND. P/ DOENÇA</div></div>
