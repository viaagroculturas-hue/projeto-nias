              <div class="alert-card-header"><span class="alert-card-title">ESTRESSE HÍDRICO</span><span class="severity alta">ALTA</span></div>
              <div class="alert-card-body">Oeste da Bahia (MATOPIBA) e Norte do MT. NDVI ▼ -0.07 em 14 dias. Umidade &lt; 22%.</div>
              <div class="alert-time" id="at-1">--</div>
            </div>
            <div class="alert-card" onclick="showPanel('map')">
              <div class="alert-card-header"><span class="alert-card-title">SUSPEITA PRAGA/DOENÇA</span><span class="severity media">MÉDIA</span></div>
              <div class="alert-card-body">Norte do PR / Sul do MS. Possível ferrugem asiática ou lagarta-do-cartucho.</div>
              <div class="alert-time" id="at-2">--</div>
            </div>
            <div class="alert-card" onclick="showPanel('logistica')">
              <div class="alert-card-header"><span class="alert-card-title">GARGALO LOGÍSTICO</span><span class="severity alta">ALTA</span></div>
              <div class="alert-card-body">BR-163 a 82%. Fluxo de veículos +34%. Porto Santos: saturação iminente.</div>
              <div class="alert-time" id="at-3">--</div>
            </div>
            <div class="alert-card" onclick="showPanel('oferta')">
              <div class="alert-card-header"><span class="alert-card-title">ANOMALIA TÉRMICA</span><span class="severity media">MÉDIA</span></div>
              <div class="alert-card-body">Cinturão verde SP/MG/PR. +2.1°C acima da média. Redução 8–15% em hortifrutis.</div>
              <div class="alert-time" id="at-4">--</div>
            </div>
          </div>
        </div>
        <div class="ov-right">
          <div class="ov-chart-area">
            <div class="ov-chart-title">NDVI — SÉRIES TEMPORAIS EM TEMPO REAL (ÚLTIMAS 60 LEITURAS)</div>
            <div class="ov-chart-wrap"><canvas id="chartNdvi"></canvas></div>
          </div>
        </div>
        <div class="live-feed">
          <div class="lf-title"><span class="pulse" style="width:6px;height:6px;"></span> FEED DE EVENTOS</div>
          <div class="lf-list" id="live-feed-list"></div>
        </div>
      </div>
    </div>

    <!-- ═══ PANEL: MAP ═══ -->
    <div class="panel" id="panel-map">
      <div class="panel-header">
        <span class="panel-title">MAPA GEO-IA — SEGMENTAÇÃO SEMÂNTICA</span>
        <span class="panel-badge">Sentinel-2 + SAR</span>
        <span class="panel-badge ok">RESOLUÇÃO 10m</span>
        <span class="badge-live">● LIVE</span>
        <div style="margin-left:auto;display:flex;align-items:center;gap:4px;">
          <span style="font-size:9px;color:var(--text2);margin-right:4px;letter-spacing:1px;">DEEP DIVE:</span>
          <button id="zoom-btn-0" onclick="setZoomLevel(0)" style="background:rgba(0,212,255,.15);border:1px solid var(--accent);color:var(--accent);font-family:var(--font);font-size:9px;padding:3px 8px;border-radius:3px;cursor:pointer;letter-spacing:1px;">Z0 NACIONAL</button>
          <button id="zoom-btn-1" onclick="setZoomLevel(1)" style="background:none;border:1px solid var(--border);color:var(--text2);font-family:var(--font);font-size:9px;padding:3px 8px;border-radius:3px;cursor:pointer;letter-spacing:1px;">Z1 ESTADUAL</button>
          <button id="zoom-btn-2" onclick="setZoomLevel(2)" style="background:none;border:1px solid var(--border);color:var(--text2);font-family:var(--font);font-size:9px;padding:3px 8px;border-radius:3px;cursor:pointer;letter-spacing:1px;">Z2 PROPRIEDADE</button>
          <span id="zoom-label" style="font-size:9px;color:var(--accent2);margin-left:6px;">Cores por estado · Produtividade geral</span>
        </div>
      </div>
      <div id="map-container">
        <div id="map"></div>
        <div class="map-controls">
          <div class="map-ctrl-title">CAMADAS ATIVAS</div>
          <div class="layer-toggle"><input type="checkbox" id="l1" checked onchange="toggleLayer('soja',this)"><label for="l1">Soja (10m)</label></div>
          <div class="layer-toggle"><input type="checkbox" id="l2" checked onchange="toggleLayer('milho',this)"><label for="l2">Milho (10m)</label></div>
          <div class="layer-toggle"><input type="checkbox" id="l3" onchange="toggleLayer('cana',this)"><label for="l3">Cana-de-Açúcar</label></div>
          <div class="layer-toggle"><input type="checkbox" id="l4" onchange="toggleLayer('pastagem',this)"><label for="l4">Pastagem / Pecuária</label></div>
          <div class="layer-toggle"><input type="checkbox" id="l5" onchange="toggleLayer('horti',this)"><label for="l5">Horticultura (3m)</label></div>
          <div class="layer-toggle"><input type="checkbox" id="l6" checked onchange="toggleLayer('alertas',this)"><label for="l6">Anomalias / Alertas</label></div>
          <div class="layer-toggle"><input type="checkbox" id="l7" checked onchange="toggleLayer('portos',this)"><label for="l7">Portos / Logística</label></div>
          <div class="layer-toggle"><input type="checkbox" id="l8" checked onchange="toggleLayer('tomate-mesa',this)"><label for="l8" style="color:var(--accent)">🍅 Tomate Mesa</label></div>
          <div class="layer-toggle"><input type="checkbox" id="l9" checked onchange="toggleLayer('tomate-ind',this)"><label for="l9" style="color:var(--accent3)">🍅 Tomate Indústria</label></div>
          <div style="margin-top:6px;">
            <div class="map-ctrl-title">LEGENDA NDVI</div>
            <div class="legend-item"><div class="legend-dot" style="background:#00a550"></div><span class="legend-label">&gt; 0.70 — Saúde plena</span></div>
            <div class="legend-item"><div class="legend-dot" style="background:#7ec850"></div><span class="legend-label">0.50–0.70 — Normal</span></div>
            <div class="legend-item"><div class="legend-dot" style="background:#ffc107"></div><span class="legend-label">0.30–0.50 — Atenção</span></div>
            <div class="legend-item"><div class="legend-dot" style="background:#ff3d3d"></div><span class="legend-label">&lt; 0.30 — Crítico</span></div>
          </div>
        </div>
        <div class="map-sat-bar">
          <div class="sat-title">STATUS ORBITAL — TEMPO REAL</div>
          <div class="sat-row"><span class="sat-name">Sentinel-2A</span><span class="sat-val" id="ms-s2a">Passando em 00:42</span></div>
          <div class="sat-progress"><div class="sat-fill" id="sf-s2a" style="width:72%"></div></div>
          <div class="sat-row" style="margin-top:5px"><span class="sat-name">Sentinel-1 SAR</span><span class="sat-val" id="ms-s1">Em órbita ativo</span></div>
          <div class="sat-progress"><div class="sat-fill" id="sf-s1" style="width:100%;background:var(--accent2)"></div></div>
          <div class="sat-row" style="margin-top:5px"><span class="sat-name">PlanetScope</span><span class="sat-val" id="ms-ps">Passando em 01:15</span></div>
          <div class="sat-progress"><div class="sat-fill" id="sf-ps" style="width:45%"></div></div>
        </div>
        <div class="map-stats">
          <p>Cobertura ativa: <strong id="map-cov">98.7%</strong> do território</p>
          <p>Última leitura: <strong id="map-time">--</strong></p>
          <p>Polígonos ativos: <strong id="map-poly">14.832</strong></p>
          <p>Anomalias detectadas: <strong style="color:var(--danger)" id="map-anom">4</strong></p>
        </div>
      </div>
    </div>

    <!-- ═══ PANEL: LOGÍSTICA ═══ -->
    <div class="panel" id="panel-logistica">
      <div class="panel-header">
        <span class="panel-title">INTELIGÊNCIA LOGÍSTICA — SUPER IA · CAMPO → PORTOS</span>
        <span class="panel-badge danger" id="ph-br163">BR-163: 82%</span>
        <span class="panel-badge warn" id="ph-santos">SANTOS: 74%</span>
        <span class="panel-badge ok" id="ph-ferro">FERROV.: 61%</span>
        <span class="panel-badge" id="ph-iel" style="background:rgba(0,255,136,.1);color:#00ff88;border-color:#00ff88;">IEL: 68</span>
        <span class="badge-live">● LIVE</span>
      </div>
      <!-- KPI STRIP -->
      <div style="display:flex;align-items:center;gap:20px;padding:5px 14px;background:var(--bg3);border-bottom:1px solid var(--border);flex-shrink:0;">
        <div style="display:flex;align-items:center;gap:8px;">
          <span style="font-size:9px;color:var(--text2);letter-spacing:1px;">CUSTO BRASIL / HORA</span>
          <span id="log-custo-val" style="font-size:16px;font-weight:bold;color:var(--danger);font-family:var(--font);">R$ 2.847.000</span>
          <span style="font-size:9px;color:var(--text2);">em perdas logísticas detectadas</span>
        </div>
        <div style="width:1px;height:30px;background:var(--border);"></div>
        <div style="display:flex;align-items:center;gap:8px;">
          <span style="font-size:9px;color:var(--text2);letter-spacing:1px;">ÍNDICE EFICIÊNCIA LOGÍSTICA</span>
          <div style="width:120px;height:8px;background:#0e2d4a;border-radius:4px;overflow:hidden;">
            <div id="iel-bar" style="height:100%;width:68%;background:linear-gradient(90deg,#ffc107,#00ff88);border-radius:4px;transition:width 2s;"></div>
          </div>
          <span id="iel-val" style="font-size:14px;font-weight:bold;color:#00ff88;font-family:var(--font);">68/100</span>
        </div>
        <div style="margin-left:auto;font-size:9px;color:var(--text2);">ANTT · AIS Marítimo · GPS Frotas · Satélite</div>
      </div>
      <div style="flex:1;display:flex;overflow:hidden;">
        <!-- LEFT: SANKEY CANVAS -->
        <div class="log-left" style="flex:1;display:flex;flex-direction:column;padding:0;border-right:1px solid var(--border);">
          <div style="padding:5px 12px;display:flex;justify-content:space-between;align-items:center;flex-shrink:0;border-bottom:1px solid var(--border);">
            <span style="color:var(--accent);font-size:10px;letter-spacing:1px;">SANKEY DINÂMICO — FLUXO PONTA A PONTA · PARTÍCULAS EM TEMPO REAL</span>
            <span style="font-size:9px;color:var(--text2);" id="log-subtitle">Partícula vermelha = gargalo · verde = livre · amarela = atenção</span>
          </div>
          <div class="sankey-wrap" style="flex:1;min-height:0;"><canvas id="chartSankey"></canvas>
            <!-- ECO-SCORE overlay -->
            <div style="position:absolute;top:30px;left:6px;z-index:10;background:rgba(5,14,26,.88);border:1px solid var(--border);border-radius:5px;padding:6px 10px;width:170px;">
              <div style="font-size:9px;color:var(--accent);letter-spacing:1px;margin-bottom:4px;">ECO-SCORE MALHA</div>
              <div style="display:flex;align-items:center;gap:6px;margin-bottom:4px;">
                <div style="flex:1;height:6px;background:#0e2d4a;border-radius:3px;overflow:hidden;"><div id="eco-bar" style="height:100%;width:55%;background:linear-gradient(90deg,#ff3d3d,#ffc107);border-radius:3px;transition:width 2s;"></div></div>
                <span id="eco-val" style="font-size:11px;font-weight:bold;color:var(--warn);font-family:var(--font);">55</span>
              </div>
              <div style="font-size:9px;color:var(--text2);display:flex;justify-content:space-between;">
                <span>CO₂: <span id="eco-co2" style="color:var(--warn);">2.4 kg/t</span></span>
                <span>Ocioso: <span id="eco-idle" style="color:var(--danger);">38%</span></span>
              </div>
              <div id="eco-tip" style="font-size:8px;color:var(--text2);margin-top:3px;line-height:1.4;">Frota parada na BR-163 emit. 18% acima da base</div>
            </div>
          </div>
          <!-- MATRIZ DE ARBITRAGEM -->
          <div id="arb-strip" style="height:192px;flex-shrink:0;border-top:1px solid var(--border);display:flex;flex-direction:column;overflow:hidden;">
            <div style="padding:4px 12px;background:var(--bg3);border-bottom:1px solid var(--border);display:flex;align-items:center;gap:8px;flex-shrink:0;">
              <span style="color:var(--accent);font-size:10px;letter-spacing:2px;">ACTION ROOM — ARBITRAGEM PRESCRITIVA</span>
              <span style="font-size:9px;color:var(--text2);">Origem vs Porto · Frete IA detectado via partículas</span>
              <span class="pulse" style="width:5px;height:5px;background:var(--accent2);display:inline-block;border-radius:50%;margin-left:auto;"></span>
            </div>
            <div style="flex:1;overflow-x:auto;">
              <table style="width:100%;border-collapse:collapse;min-width:620px;">
                <thead><tr>
                  <th style="background:var(--bg3);color:var(--accent);font-size:9px;padding:4px 8px;text-align:left;position:sticky;top:0;letter-spacing:1px;">MUNICÍPIO</th>
                  <th style="background:var(--bg3);color:var(--accent);font-size:9px;padding:4px 8px;text-align:left;position:sticky;top:0;">CULTURA</th>
                  <th style="background:var(--bg3);color:var(--accent);font-size:9px;padding:4px 8px;text-align:right;position:sticky;top:0;">PREÇO ORIGEM</th>
                  <th style="background:var(--bg3);color:var(--accent);font-size:9px;padding:4px 8px;text-align:right;position:sticky;top:0;">PREÇO PORTO</th>
                  <th style="background:var(--bg3);color:var(--accent);font-size:9px;padding:4px 8px;text-align:right;position:sticky;top:0;">FRETE IA</th>
                  <th style="background:var(--bg3);color:var(--accent);font-size:9px;padding:4px 8px;text-align:right;position:sticky;top:0;">SPREAD LÍQUIDO</th>
                  <th style="background:var(--bg3);color:var(--accent);font-size:9px;padding:4px 8px;text-align:left;position:sticky;top:0;min-width:220px;">RECOMENDAÇÃO IA</th>
                </tr></thead>
                <tbody id="arb-tbody"></tbody>
              </table>
            </div>
          </div>
        </div>
        <!-- RIGHT: AI CONTROL PANEL -->
        <div class="log-right" style="width:340px;display:flex;flex-direction:column;overflow:hidden;">
          <!-- ETA PREDITIVO -->
          <div style="padding:6px 12px;color:var(--accent);font-size:10px;letter-spacing:2px;border-bottom:1px solid var(--border);flex-shrink:0;display:flex;align-items:center;gap:6px;">
            <span class="pulse" style="width:5px;height:5px;background:var(--accent);display:inline-block;border-radius:50%;"></span>
            ETA PREDITIVO — IA DE ROTAS
          </div>
          <div id="eta-cards" style="padding:6px;display:flex;flex-direction:column;gap:4px;flex-shrink:0;border-bottom:1px solid var(--border);"></div>
          <!-- REROUTING SUGGESTION -->
          <div style="padding:7px 10px;border-bottom:1px solid var(--border);flex-shrink:0;">
            <div style="background:rgba(0,212,255,.07);border:1px solid rgba(0,212,255,.2);border-radius:5px;padding:8px 10px;">
              <div style="font-size:9px;color:var(--accent);letter-spacing:1px;margin-bottom:5px;">SUGESTÃO DE RE-ROTEAMENTO — IA</div>
              <div id="reroute-msg" style="font-size:10px;color:var(--text);line-height:1.5;margin-bottom:7px;">A IA sugere desviar 20% do fluxo BR-163 para a Ferrovia Norte-Sul. Economia estimada: <span style="color:#00ff88;font-weight:bold;">R$ 1,2M</span> e <span style="color:#00ff88;font-weight:bold;">-6h</span> de ETA.</div>
              <button id="reroute-btn" onclick="applyReroute()" style="background:var(--accent);color:#050e1a;border:none;padding:5px 12px;font-family:var(--font);font-size:10px;font-weight:bold;border-radius:3px;cursor:pointer;letter-spacing:1px;">⚡ RE-ROTEAR VIA IA</button>
              <span id="reroute-status" style="margin-left:8px;font-size:9px;color:var(--text2);"></span>
            </div>
          </div>
          <!-- AIS RADAR NAVIOS -->
          <div style="padding:5px 12px;color:var(--accent);font-size:10px;letter-spacing:2px;border-bottom:1px solid var(--border);flex-shrink:0;display:flex;align-items:center;gap:6px;">
            <span class="pulse" style="width:5px;height:5px;background:var(--warn);display:inline-block;border-radius:50%;"></span>
            RADAR AIS — NAVIOS NOS PORTOS
          </div>
          <div id="ais-panel" style="padding:6px;display:flex;flex-direction:column;gap:4px;flex-shrink:0;border-bottom:1px solid var(--border);"></div>
          <!-- SATURATION CORRIDORS -->
          <div style="padding:6px 12px;color:var(--accent);font-size:10px;letter-spacing:2px;border-bottom:1px solid var(--border);flex-shrink:0;">SATURAÇÃO POR CORREDOR</div>
          <div style="flex:1;overflow-y:auto;">
            <div class="route-card danger" id="rc-br163">
              <div class="route-name">BR-163 (Sorriso → Miritituba)</div>
              <div class="route-detail" id="rd-br163-flow">Fluxo: 3.240 veíc/dia (+34%)</div>
              <div class="route-detail">Status: <span style="color:var(--danger)" id="br163-status-txt">CRÍTICO</span></div>
              <div class="progress-bar"><div class="progress-fill" id="pf-br163" style="width:82%;background:var(--danger)"></div></div>
              <div class="counter-row"><span class="route-detail">Saturação:</span><span class="counter-val" id="cv-br163" style="color:var(--danger)">82%</span></div>
              <div class="speed-meter">
                <div class="speed-row"><span class="speed-label">Vel. média (últ. 5km)</span><span class="speed-val" id="br163-speed" style="color:var(--danger)">42 km/h</span></div>
                <div class="speed-bar"><div class="speed-fill" id="br163-speed-bar" style="width:49%;background:var(--danger)"></div></div>
                <div class="speed-row" style="margin-top:3px;"><span class="speed-label">Limite: 80km/h</span><span id="br163-speed-pct" style="color:var(--danger);font-size:10px;">▼ -47% GARGALO</span></div>
              </div>
            </div>
            <div class="route-card warn" id="rc-santos">
              <div class="route-name">Porto de Santos</div>
              <div class="route-detail" id="rd-santos-flow">Berços: 6/8 ocupados</div>
              <div class="route-detail">Status: <span style="color:var(--warn)">ATENÇÃO</span></div>
              <div class="progress-bar"><div class="progress-fill" id="pf-santos" style="width:74%;background:var(--warn)"></div></div>
              <div class="counter-row"><span class="route-detail">Saturação:</span><span class="counter-val" id="cv-santos" style="color:var(--warn)">74%</span></div>
            </div>
            <div class="route-card warn" id="rc-paranagua">
              <div class="route-name">Porto de Paranaguá</div>
              <div class="route-detail" id="rd-par-flow">Berços: 5/7 ocupados</div>
              <div class="route-detail">Status: <span style="color:var(--warn)">ATENÇÃO</span></div>
              <div class="progress-bar"><div class="progress-fill" id="pf-par" style="width:71%;background:var(--warn)"></div></div>
              <div class="counter-row"><span class="route-detail">Saturação:</span><span class="counter-val" id="cv-par" style="color:var(--warn)">71%</span></div>
            </div>
            <div class="route-card ok">
              <div class="route-name">Ferroviário RUMO/VLI</div>
              <div class="route-detail" id="rd-ferro-flow">Composições: 18/30 ativas</div>
              <div class="route-detail">Status: <span style="color:var(--accent2)">NORMAL</span></div>
              <div class="progress-bar"><div class="progress-fill" id="pf-ferro" style="width:61%;background:var(--accent2)"></div></div>
              <div class="counter-row"><span class="route-detail">Saturação:</span><span class="counter-val" id="cv-ferro" style="color:var(--accent2)">61%</span></div>
            </div>
            <div class="route-card ok">
              <div class="route-name">Porto de Rosário (AR)</div>
              <div class="route-detail" id="rd-ros-flow">Hidrovia: fluxo normal</div>
              <div class="progress-bar"><div class="progress-fill" id="pf-ros" style="width:48%;background:var(--accent2)"></div></div>
              <div class="counter-row"><span class="route-detail">Saturação:</span><span class="counter-val" id="cv-ros" style="color:var(--accent2)">48%</span></div>
            </div>
            <div class="route-card ok">
              <div class="route-name">BR-364 (MT → RO/AC)</div>
              <div class="route-detail" id="rd-br364-flow">Fluxo: 1.820 veíc/dia</div>
              <div class="progress-bar"><div class="progress-fill" id="pf-br364" style="width:55%;background:var(--accent2)"></div></div>
              <div class="counter-row"><span class="route-detail">Saturação:</span><span class="counter-val" id="cv-br364" style="color:var(--accent2)">55%</span></div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- ═══ PANEL: OFERTA ═══ -->
    <div class="panel" id="panel-oferta">
      <div class="panel-header">
        <span class="panel-title">TERMINAL DE ARBITRAGEM — CEASAS · SUPER IA · ALTA FREQUÊNCIA</span>
        <span class="panel-badge ok" id="ceasa-best-badge">🏆 MELHOR: CEAGESP +R$74/cx</span>
        <span class="panel-badge danger" id="ceasa-opp-count">● 3 OPORTUNIDADES</span>
        <span class="panel-badge warn" id="ph-delta2">δ_clima = 0.968</span>
        <span class="badge-live">● LIVE</span>
      </div>
      <!-- KPI HFT strip -->
      <div style="display:flex;align-items:stretch;flex-shrink:0;border-bottom:1px solid var(--border);background:var(--bg3);">
        <div style="flex:1;padding:5px 14px;border-right:1px solid var(--border);display:flex;align-items:center;gap:10px;">
          <span style="font-size:9px;color:var(--text2);letter-spacing:1px;">MELHOR SPREAD ATUAL</span>
          <span id="ceasa-spread-best" style="font-size:16px;font-weight:bold;color:var(--accent2);font-family:var(--font);">+ R$ 74,30/cx</span>
          <span style="font-size:9px;color:var(--text2);" id="ceasa-spread-where">CEAGESP · Tomate Mesa</span>
        </div>
        <div style="flex:1;padding:5px 14px;border-right:1px solid var(--border);display:flex;align-items:center;gap:10px;">
          <span style="font-size:9px;color:var(--text2);letter-spacing:1px;">FRETE MÉDIO NACIONAL IA</span>
          <span id="ceasa-frete-avg" style="font-size:16px;font-weight:bold;color:var(--warn);font-family:var(--font);">R$ 13,80/cx</span>
          <span id="ceasa-frete-var" style="font-size:10px;color:var(--danger);">↑ +2.4%</span>
        </div>
