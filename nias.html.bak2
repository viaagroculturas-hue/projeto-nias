          <!-- DIGITAL TWIN SIMULATOR BAR -->
          <div id="sim-bar" style="height:38px;background:rgba(0,212,255,.05);border-bottom:1px solid rgba(0,212,255,.2);display:flex;align-items:center;padding:0 10px;gap:8px;flex-shrink:0;overflow:hidden;">
            <span style="font-size:9px;color:var(--accent);letter-spacing:1px;white-space:nowrap;">⬡ GÊMEO DIGITAL:</span>
            <select id="sim-mun" style="background:var(--bg);border:1px solid var(--border);color:var(--text);font-family:var(--font);font-size:9px;padding:2px 5px;border-radius:3px;outline:none;max-width:130px;">
              <option value="all">Todos os municípios</option>
            </select>
            <span style="font-size:9px;color:var(--text2);white-space:nowrap;">Seca (dias):</span>
            <input type="range" id="sim-drought" min="0" max="30" value="0" oninput="previewSimulation()" style="width:80px;accent-color:var(--accent);cursor:pointer;">
            <span id="sim-drought-val" style="font-size:9px;color:var(--warn);min-width:18px;">0d</span>
            <span style="font-size:9px;color:var(--text2);white-space:nowrap;">ΔT:</span>
            <input type="range" id="sim-heat" min="-8" max="10" value="0" oninput="previewSimulation()" style="width:60px;accent-color:#ff6b35;cursor:pointer;">
            <span id="sim-heat-val" style="font-size:9px;color:var(--warn);min-width:28px;">+0°C</span>
            <button onclick="applySimulation()" style="background:var(--accent);color:#050e1a;border:none;padding:3px 9px;font-family:var(--font);font-size:9px;font-weight:bold;border-radius:3px;cursor:pointer;white-space:nowrap;">▶ SIMULAR</button>
            <button onclick="resetSimulation()" style="background:none;border:1px solid var(--border);color:var(--text2);padding:3px 7px;font-family:var(--font);font-size:9px;border-radius:3px;cursor:pointer;">RESET</button>
            <span id="sim-impact" style="font-size:9px;color:var(--warn);flex:1;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;"></span>
          </div>
          <!-- DRILL-DOWN BREADCRUMB BAR -->
          <div style="height:30px;background:rgba(0,212,255,.04);border-bottom:1px solid rgba(0,212,255,.15);display:flex;align-items:center;padding:0 12px;gap:10px;flex-shrink:0;overflow:hidden;">
            <span style="font-size:9px;color:var(--accent);letter-spacing:1px;white-space:nowrap;">IBGE DRILL-DOWN:</span>
            <span id="drill-breadcrumb" style="font-size:10px;color:var(--text);font-family:var(--font);">🌎 <b>Brasil</b></span>
            <button onclick="drillUp()" style="background:none;border:1px solid var(--border);color:var(--text2);padding:1px 7px;font-family:var(--font);font-size:9px;border-radius:3px;cursor:pointer;white-space:nowrap;">↩ Voltar</button>
            <span id="drill-status" style="font-size:9px;color:var(--accent);flex:1;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;"></span>
          </div>
          <!-- CONTROLS BAR -->
          <div style="height:34px;background:var(--bg3);border-bottom:1px solid var(--border);display:flex;align-items:center;padding:0 12px;gap:8px;flex-shrink:0;overflow:hidden;">
            <select id="mun-filter" onchange="trocarCultura(this.value)" style="background:var(--bg);border:1px solid var(--border);color:var(--text);font-family:var(--font);font-size:10px;padding:2px 6px;border-radius:3px;outline:none;">
              <option value="all">Todas as culturas</option>
              <option value="soja">Soja</option>
              <option value="milho">Milho</option>
              <option value="tomate">Tomate Mesa</option>
              <option value="cebola">Cebola</option>
              <option value="manga">Manga</option>
              <option value="uva">Uva</option>
            </select>
            <select id="mun-country" onchange="filterMunicipalMap(document.getElementById('mun-filter').value)" style="background:var(--bg);border:1px solid var(--border);color:var(--text);font-family:var(--font);font-size:10px;padding:2px 6px;border-radius:3px;outline:none;">
              <option value="all">Todos os países</option>
              <option value="BR">Brasil</option>
              <option value="AR">Argentina</option>
              <option value="PY">Paraguai</option>
              <option value="UY">Uruguai</option>
            </select>
            <div style="width:1px;height:18px;background:var(--border);flex-shrink:0;"></div>
            <span style="font-size:9px;color:var(--text2);white-space:nowrap;">CAMADAS:</span>
            <button id="mun-lyr-prod" onclick="toggleMunLayer('prod')" class="lyr-btn active" title="Produção / Calor">⬛ Produção</button>
            <button id="mun-lyr-logistics" onclick="toggleMunLayer('logistics')" class="lyr-btn" title="Vetores CEASA">→ Logística</button>
            <button id="mun-lyr-risk" onclick="toggleMunLayer('risk')" class="lyr-btn active" title="Alertas de risco">⚠ Risco</button>
            <button id="mun-lyr-sidra" onclick="fetchSidraLayer()" class="lyr-btn" title="Dados SIDRA/PAM">📡 SIDRA PAM</button>
            <span style="margin-left:auto;font-size:9px;color:var(--text2);white-space:nowrap;">Hover = tooltip IA | Clique estado = drill-down</span>
          </div>
          <div style="flex:1;display:flex;overflow:hidden;">

            <!-- CULTURE FILTER SIDEBAR -->
            <div style="width:165px;flex-shrink:0;border-right:1px solid var(--border);display:flex;flex-direction:column;overflow:hidden;background:var(--bg2);">
              <div style="padding:5px 10px;font-size:9px;color:var(--accent);letter-spacing:1px;border-bottom:1px solid var(--border);flex-shrink:0;display:flex;align-items:center;gap:6px;">
                <span class="pulse" style="width:5px;height:5px;background:var(--accent);border-radius:50%;display:inline-block;"></span>FILTRO MULTICULTURAL
              </div>
              <div style="flex:1;overflow-y:auto;padding:6px;">
                <div style="font-size:8px;color:var(--text2);letter-spacing:1px;padding:2px 0 4px;border-bottom:1px solid var(--border);margin-bottom:4px;">GRÃOS E FIBRAS</div>
                <button class="cult-btn" id="cb-soja"     onclick="trocarCultura('soja')">🌿 Soja</button>
                <button class="cult-btn" id="cb-milho"    onclick="trocarCultura('milho')">🌽 Milho</button>
                <button class="cult-btn" id="cb-algodao"  onclick="trocarCultura('algodao')">🧵 Algodão</button>
                <button class="cult-btn" id="cb-arroz"    onclick="trocarCultura('arroz')">🌾 Arroz</button>
                <button class="cult-btn" id="cb-feijao"   onclick="trocarCultura('feijao')">🫘 Feijão</button>
                <div style="font-size:8px;color:var(--text2);letter-spacing:1px;padding:2px 0 4px;border-bottom:1px solid var(--border);margin:7px 0 4px;">HORTIFRUTI (iRed)</div>
                <button class="cult-btn" id="cb-tomate"     onclick="trocarCultura('tomate')">🍅 Tomate Mesa</button>
                <button class="cult-btn" id="cb-tomate-ind" onclick="trocarCultura('tomate-ind')">🍅 Tomate Ind.</button>
                <button class="cult-btn" id="cb-cebola"   onclick="trocarCultura('cebola')">🧅 Cebola</button>
                <button class="cult-btn" id="cb-pimentao" onclick="trocarCultura('pimentao')">🫑 Pimentão</button>
                <button class="cult-btn" id="cb-batata"   onclick="trocarCultura('batata')">🥔 Batata</button>
                <button class="cult-btn" id="cb-cenoura"  onclick="trocarCultura('cenoura')">🥕 Cenoura</button>
                <div style="font-size:8px;color:var(--text2);letter-spacing:1px;padding:2px 0 4px;border-bottom:1px solid var(--border);margin:7px 0 4px;">FRUTICULTURA</div>
                <button class="cult-btn" id="cb-manga"    onclick="trocarCultura('manga')">🥭 Manga</button>
                <button class="cult-btn" id="cb-uva"      onclick="trocarCultura('uva')">🍇 Uva</button>
                <button class="cult-btn" id="cb-laranja"  onclick="trocarCultura('laranja')">🍊 Laranja</button>
                <button class="cult-btn" id="cb-banana"   onclick="trocarCultura('banana')">🍌 Banana</button>
                <button class="cult-btn" id="cb-maca"     onclick="trocarCultura('maca')">🍎 Maçã</button>
                <button class="cult-btn" id="cb-melao"    onclick="trocarCultura('melao')">🍈 Melão</button>
                <div style="font-size:8px;color:var(--text2);letter-spacing:1px;padding:2px 0 4px;border-bottom:1px solid var(--border);margin:7px 0 4px;">VISÃO GERAL</div>
                <button class="cult-btn active" id="cb-all" onclick="trocarCultura('all')">🌍 Todas as Culturas</button>
              </div>
              <!-- VBP TOTAL FOOTER -->
              <div style="padding:7px 10px;border-top:1px solid var(--border);flex-shrink:0;">
                <div style="font-size:8px;color:var(--text2);letter-spacing:1px;margin-bottom:2px;">VBP ESTIMADO 2026</div>
                <div id="sidra-vbp-total" style="font-size:15px;font-weight:bold;color:var(--accent2);font-family:var(--font);">—</div>
                <div id="sidra-mun-count" style="font-size:9px;color:var(--text2);">— municípios ativos</div>
              </div>
            </div>

            <!-- MAP + OVERLAYS -->
            <div style="flex:1;position:relative;">
              <div id="map-municipal" style="width:100%;height:100%;"></div>
              <!-- LAYERS TOGGLE (top-right of map) -->
              <div style="position:absolute;top:8px;right:8px;z-index:1001;display:flex;gap:4px;flex-wrap:wrap;justify-content:flex-end;">
                <button id="btn-prod-shadow" onclick="toggleProdShadow()" class="lyr-btn" title="Sombra de Produção: OFF — clique para ligar" style="background:rgba(5,14,26,.88);border:1px solid var(--border);font-size:9px;padding:3px 8px;">🌑 Sombra</button>
                <button id="btn-risk-radar" onclick="setRiskMode('radar')" class="lyr-btn active" style="background:rgba(5,14,26,.88);font-size:9px;padding:3px 8px;" title="Modo Radar: pontos discretos">📍 Radar</button>
                <button id="btn-risk-impact" onclick="setRiskMode('impact')" class="lyr-btn" style="background:rgba(5,14,26,.88);font-size:9px;padding:3px 8px;" title="Modo Impacto: áreas preenchidas">🔴 Impacto</button>
                <button id="btn-risk-off" onclick="setRiskMode('off')" class="lyr-btn" style="background:rgba(5,14,26,.88);font-size:9px;padding:3px 8px;" title="Desligar risco">✕ Risco</button>
                <button onclick="toggleMunLayer('logistics')" id="mun-lyr-log2" class="lyr-btn" style="background:rgba(5,14,26,.88);font-size:9px;padding:3px 8px;">→ Logística</button>
              </div>
              <!-- TIME SLIDER OVERLAY -->
              <div style="position:absolute;bottom:52px;right:8px;z-index:1000;background:rgba(5,14,26,.92);border:1px solid var(--border);border-radius:6px;padding:6px 10px;min-width:230px;">
                <div style="display:flex;align-items:center;gap:6px;margin-bottom:4px;">
                  <span style="font-size:9px;color:var(--accent);letter-spacing:1px;">FILTRO DE SAFRA</span>
                  <span id="sidra-year-val" style="font-size:13px;font-weight:bold;color:var(--accent2);margin-left:auto;font-family:var(--font);">2024</span>
                </div>
                <input type="range" id="sidra-year-slider" min="2020" max="2026" value="2024" step="1"
                  onchange="onSafraSlider(this.value)"
                  style="width:100%;accent-color:var(--accent);cursor:pointer;">
                <div style="display:flex;justify-content:space-between;margin-top:2px;">
                  <span style="font-size:8px;color:var(--text2);">2020 real</span>
                  <span style="font-size:8px;color:var(--warn);">NIA$ 2026 →</span>
                </div>
                <div id="sidra-year-note" style="font-size:9px;color:var(--accent);margin-top:3px;">Dados reais SIDRA/PAM IBGE</div>
              </div>
              <!-- LEGEND OVERLAY -->
              <div style="position:absolute;bottom:8px;left:8px;z-index:999;background:rgba(5,14,26,.92);border:1px solid var(--border);border-radius:6px;padding:8px 12px;font-size:10px;">
                <div id="sidra-legend" style="color:var(--accent);letter-spacing:1px;margin-bottom:5px;font-size:9px;">LEGENDA COROPLETA</div>
                <div id="sidra-legend-items" style="display:flex;flex-direction:column;gap:3px;">
                  <div style="display:flex;align-items:center;gap:6px;"><div style="width:10px;height:10px;background:#2d7a1f;border-radius:2px;"></div><span style="color:var(--text2);font-size:9px;">Soja</span></div>
                  <div style="display:flex;align-items:center;gap:6px;"><div style="width:10px;height:10px;background:#c8a000;border-radius:2px;"></div><span style="color:var(--text2);font-size:9px;">Milho</span></div>
                  <div style="display:flex;align-items:center;gap:6px;"><div style="width:10px;height:10px;background:#cc2200;border-radius:2px;"></div><span style="color:var(--text2);font-size:9px;">Tomate</span></div>
                  <div style="display:flex;align-items:center;gap:6px;"><div style="width:10px;height:10px;background:#ff8c00;border-radius:2px;"></div><span style="color:var(--text2);font-size:9px;">Manga/Fruticultura</span></div>
                  <div style="display:flex;align-items:center;gap:6px;"><div style="width:10px;height:10px;background:#00ff88;border-radius:2px;border:1px solid #00ff88;"></div><span style="color:#00ff88;font-size:9px;">⭐ Top 10 Nacional</span></div>
                </div>
                <div style="margin-top:5px;color:var(--text2);font-size:9px;">Brilho = volume produção</div>
              </div>
            </div>

          </div>
        </div>

        <!-- RIGHT: YIELD TABLE + ANOMALY RADAR -->
        <div style="width:420px;display:flex;flex-direction:column;overflow:hidden;flex-shrink:0;">

          <!-- Rm TABLE -->
          <div style="height:50%;border-bottom:1px solid var(--border);display:flex;flex-direction:column;overflow:hidden;">
            <div style="padding:6px 12px;color:var(--accent);font-size:10px;letter-spacing:2px;border-bottom:1px solid var(--border);flex-shrink:0;display:flex;justify-content:space-between;">
              <span>R_m POR MUNICÍPIO</span>
              <span style="color:var(--text2);font-size:9px;">Rm = Área × NDVI × Coef. Manejo</span>
            </div>
            <div style="flex:1;overflow-y:auto;">
              <table style="width:100%;border-collapse:collapse;">
                <thead><tr>
                  <th style="background:var(--bg3);color:var(--accent);font-size:9px;padding:5px 8px;text-align:left;position:sticky;top:0;letter-spacing:1px;">MUNICÍPIO</th>
                  <th style="background:var(--bg3);color:var(--accent);font-size:9px;padding:5px 8px;text-align:left;position:sticky;top:0;">CULTURA</th>
                  <th style="background:var(--bg3);color:var(--accent);font-size:9px;padding:5px 8px;text-align:right;position:sticky;top:0;">NDVI</th>
                  <th style="background:var(--bg3);color:var(--accent);font-size:9px;padding:5px 8px;text-align:right;position:sticky;top:0;">Rm (t/ha)</th>
                  <th style="background:var(--bg3);color:var(--accent);font-size:9px;padding:5px 8px;text-align:center;position:sticky;top:0;">STATUS</th>
                </tr></thead>
                <tbody id="mun-table-body"></tbody>
              </table>
            </div>
          </div>

          <!-- ANOMALY RADAR FEED -->
          <div style="flex:1;display:flex;flex-direction:column;overflow:hidden;">
            <div style="padding:6px 12px;color:var(--danger);font-size:10px;letter-spacing:2px;border-bottom:1px solid var(--border);flex-shrink:0;display:flex;align-items:center;gap:8px;">
              <span class="pulse" style="width:6px;height:6px;background:var(--danger);"></span>
              RADAR DE ANOMALIAS LOCALIZADAS
            </div>
            <div id="anomaly-radar-list" style="flex:1;overflow-y:auto;padding:4px 0;"></div>
          </div>
        </div>

      </div>
    </div>

    <!-- ═══ PANEL: MACRO-POLOS ═══ -->
    <div class="panel" id="panel-macropolos">
      <div class="panel-header">
        <span class="panel-title">MACRO-POLOS — FULL SCAN CONTINENTAL · BRASIL</span>
        <span class="panel-badge ok">4 ESPECIALIZAÇÕES ATIVAS</span>
        <span class="panel-badge" id="mp-scan-badge">SCAN CONTINENTAL: EM CURSO</span>
        <span class="badge-live">● LIVE</span>
      </div>
      <!-- Full Scan Output Bar -->
      <div style="display:flex;gap:0;flex-shrink:0;border-bottom:1px solid var(--border);">
        <div style="flex:1;padding:6px 14px;border-right:1px solid var(--border);display:flex;align-items:center;gap:10px;">
          <span style="font-size:9px;color:var(--text2);letter-spacing:1px;">GRÃOS</span>
          <span id="mp-vol-graos" style="font-size:18px;font-weight:bold;color:var(--accent);font-family:var(--font);">247.2 Mt</span>
          <span id="mp-var-graos" style="font-size:10px;color:var(--danger);">▼ -3.1%</span>
          <span style="font-size:9px;color:var(--text2);">Soja+Milho+Cana+Algodão</span>
        </div>
        <div style="flex:1;padding:6px 14px;border-right:1px solid var(--border);display:flex;align-items:center;gap:10px;">
          <span style="font-size:9px;color:var(--text2);letter-spacing:1px;">HORTIFRUTIS</span>
          <span id="mp-vol-horti" style="font-size:18px;font-weight:bold;color:#00ff88;font-family:var(--font);">62.4 Mt</span>
          <span id="mp-var-horti" style="font-size:10px;color:#00ff88;">▲ +1.4%</span>
          <span style="font-size:9px;color:var(--text2);">Fresh+Irrigado+Processado</span>
        </div>
        <div style="flex:1;padding:6px 14px;display:flex;align-items:center;gap:10px;">
          <span style="font-size:9px;color:var(--text2);letter-spacing:1px;">PROTEÍNA ANIMAL</span>
          <span id="mp-vol-prot" style="font-size:18px;font-weight:bold;color:var(--warn);font-family:var(--font);">14.8 Mt</span>
          <span id="mp-var-prot" style="font-size:10px;color:var(--warn);">▲ +0.8%</span>
          <span style="font-size:9px;color:var(--text2);">Boi+Frango+Suíno+Pescado</span>
        </div>
        <div style="width:220px;padding:6px 14px;border-left:1px solid var(--border);display:flex;flex-direction:column;justify-content:center;gap:2px;">
          <div style="font-size:9px;color:var(--text2);letter-spacing:1px;">DIVERGÊNCIA MUNICIPAL NDVI</div>
          <div id="mp-ndvi-div" style="font-size:10px;color:var(--accent);">Verificando pares vizinhos...</div>
          <div style="font-size:9px;color:var(--text2);">Limiar: Δ NDVI &gt; 0.3 entre vizinhos</div>
        </div>
      </div>
      <!-- 4 Pole Cards Grid -->
      <div style="flex:1;display:grid;grid-template-columns:1fr 1fr;grid-template-rows:1fr 1fr;gap:5px;padding:5px;overflow:hidden;">

        <!-- POLO A: CINTURÃO DE COMMODITIES -->
        <div style="background:var(--bg2);border:1px solid #00a55040;border-radius:6px;display:flex;flex-direction:column;overflow:hidden;">
          <div style="background:rgba(0,165,80,.12);padding:6px 10px;border-bottom:1px solid #00a55030;display:flex;align-items:center;gap:8px;flex-shrink:0;">
            <span style="background:#00a550;color:#050e1a;font-weight:bold;font-size:10px;padding:2px 7px;border-radius:3px;">A</span>
            <span style="color:#00a550;font-size:10px;letter-spacing:1px;font-weight:bold;">CINTURÃO DE COMMODITIES — Centro-Oeste + MATOPIBA</span>
            <span id="poleA-badge" style="margin-left:auto;font-size:9px;color:#00a550;border:1px solid #00a550;padding:1px 5px;border-radius:2px;">COLHEITA ATIVA</span>
          </div>
          <div style="flex:1;display:flex;overflow:hidden;">
            <div style="flex:1;padding:6px;overflow-y:auto;border-right:1px solid var(--border);">
              <div style="font-size:9px;color:var(--text2);letter-spacing:1px;margin-bottom:4px;">MUNICÍPIOS-CHAVE · NDVI AO VIVO</div>
              <table style="width:100%;border-collapse:collapse;" id="poleA-table"></table>
            </div>
            <div style="width:160px;padding:5px;display:flex;flex-direction:column;gap:3px;flex-shrink:0;">
              <div style="font-size:9px;color:var(--text2);letter-spacing:1px;">ALERTAS IA</div>
              <div id="poleA-alerts" style="flex:1;overflow-y:auto;font-size:9px;"></div>
            </div>
          </div>
        </div>

        <!-- POLO B: EIXO HORTICULTURA -->
        <div style="background:var(--bg2);border:1px solid #00d4ff40;border-radius:6px;display:flex;flex-direction:column;overflow:hidden;">
          <div style="background:rgba(0,212,255,.10);padding:6px 10px;border-bottom:1px solid #00d4ff30;display:flex;align-items:center;gap:8px;flex-shrink:0;">
            <span style="background:#00d4ff;color:#050e1a;font-weight:bold;font-size:10px;padding:2px 7px;border-radius:3px;">B</span>
            <span style="color:#00d4ff;font-size:10px;letter-spacing:1px;font-weight:bold;">EIXO HORTICULTURA — Sudeste + Sul</span>
            <span id="poleB-badge" style="margin-left:auto;font-size:9px;color:var(--warn);border:1px solid var(--warn);padding:1px 5px;border-radius:2px;">RISCO GEADA 48h</span>
          </div>
          <div style="flex:1;display:flex;overflow:hidden;">
            <div style="flex:1;padding:6px;overflow-y:auto;border-right:1px solid var(--border);">
              <div style="font-size:9px;color:var(--text2);letter-spacing:1px;margin-bottom:4px;">MUNICÍPIOS-CHAVE · ΔT + BRIX</div>
              <table style="width:100%;border-collapse:collapse;" id="poleB-table"></table>
            </div>
            <div style="width:160px;padding:5px;display:flex;flex-direction:column;gap:3px;flex-shrink:0;">
              <div style="font-size:9px;color:var(--text2);letter-spacing:1px;">ALERTAS IA</div>
              <div id="poleB-alerts" style="flex:1;overflow-y:auto;font-size:9px;"></div>
            </div>
          </div>
        </div>

        <!-- POLO C: ARCO FRUTICULTURA IRRIGADA -->
        <div style="background:var(--bg2);border:1px solid #ff6b3540;border-radius:6px;display:flex;flex-direction:column;overflow:hidden;">
          <div style="background:rgba(255,107,53,.10);padding:6px 10px;border-bottom:1px solid #ff6b3530;display:flex;align-items:center;gap:8px;flex-shrink:0;">
            <span style="background:#ff6b35;color:#fff;font-weight:bold;font-size:10px;padding:2px 7px;border-radius:3px;">C</span>
            <span style="color:#ff6b35;font-size:10px;letter-spacing:1px;font-weight:bold;">ARCO FRUTICULTURA IRRIGADA — Nordeste</span>
            <span id="poleC-badge" style="margin-left:auto;font-size:9px;color:var(--accent2);border:1px solid var(--accent2);padding:1px 5px;border-radius:2px;">RESERVATÓRIOS: OK</span>
          </div>
          <div style="flex:1;display:flex;overflow:hidden;">
            <div style="flex:1;padding:6px;overflow-y:auto;border-right:1px solid var(--border);">
              <div style="font-size:9px;color:var(--text2);letter-spacing:1px;margin-bottom:4px;">MUNICÍPIOS-CHAVE · EVAPOTRANSPIRAÇÃO</div>
              <table style="width:100%;border-collapse:collapse;" id="poleC-table"></table>
            </div>
            <div style="width:160px;padding:5px;display:flex;flex-direction:column;gap:3px;flex-shrink:0;">
              <div style="font-size:9px;color:var(--text2);letter-spacing:1px;">ALERTAS IA</div>
              <div id="poleC-alerts" style="flex:1;overflow-y:auto;font-size:9px;"></div>
            </div>
          </div>
