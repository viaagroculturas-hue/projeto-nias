    <!-- ═══ PANEL: CHAT ═══ -->
    <div class="panel" id="panel-chat">
      <div class="panel-header">
        <span class="panel-title">ASSISTENTE DE DECISÃO — NIA$ IA</span>
        <span class="panel-badge ok">LLM ATIVO</span>
        <span class="panel-badge">Dados em tempo real integrados</span>
      </div>
      <div class="content" style="flex:1;display:flex;overflow:hidden;">
        <div class="chat-area">
          <div class="chat-messages" id="chat-messages">
            <div class="msg nias">
              <div class="msg-bubble">Sistema NIA$ inicializado. Cobertura ativa em <strong>98.7%</strong> do território agrícola sul-americano.<br><br>
              <strong style="color:var(--accent)">4 alertas críticos detectados:</strong><br>
              ⚠ Estresse Hídrico — MATOPIBA/Norte MT<br>
              ⚠ Suspeita de Praga — Norte PR/Sul MS<br>
              ⚠ Gargalo Logístico — BR-163/Santos<br>
              ⚠ Anomalia Térmica — Cinturão Verde SP/PR<br><br>
              Como posso auxiliar na sua análise hoje?</div>
              <div class="msg-meta">NIA$ · Inicialização do sistema</div>
            </div>
          </div>
          <div class="chat-input-area">
            <textarea class="chat-input" id="chat-input" rows="2" placeholder="Consulte o NIA$ sobre safras, logística, clima, preços..." onkeydown="handleKey(event)"></textarea>
            <button class="btn-send" onclick="sendMessage()">ENVIAR</button>
          </div>
        </div>
        <div class="chat-sidebar">
          <div class="chat-side-title">CONSULTAS RÁPIDAS</div>
          <button class="quick-btn" onclick="quickMsg('Qual o status atual da safra de soja no Mato Grosso?')">Status safra soja — MT</button>
          <button class="quick-btn" onclick="quickMsg('Quais regiões estão com estresse hídrico crítico agora?')">Alertas de estresse hídrico</button>
          <button class="quick-btn" onclick="quickMsg('Qual a recomendação logística para os próximos 7 dias?')">Recomendação logística</button>
          <button class="quick-btn" onclick="quickMsg('Qual o impacto da anomalia térmica nos hortifrutis?')">Impacto anomalia térmica</button>
          <button class="quick-btn" onclick="quickMsg('Gere um relatório executivo completo do status atual.')">Relatório executivo</button>
          <button class="quick-btn" onclick="quickMsg('Qual o NDVI médio por estado do Brasil agora?')">NDVI por estado</button>
          <div class="chat-side-title" style="margin-top:8px;">STATUS DOS SENSORES</div>
          <div class="status-block">
            <div class="status-row"><span class="status-label">Sentinel-2</span><span class="status-val lf-ok">● ATIVO</span></div>
            <div class="status-row"><span class="status-label">SAR Sentinel-1</span><span class="status-val lf-ok">● ATIVO</span></div>
            <div class="status-row"><span class="status-label">SMAP (NASA)</span><span class="status-val lf-ok">● ATIVO</span></div>
            <div class="status-row"><span class="status-label">ERA5 Clima</span><span class="status-val lf-ok">● ATIVO</span></div>
            <div class="status-row"><span class="status-label">API ANTT</span><span class="status-val lf-warn">● LATÊNCIA 6h</span></div>
            <div class="status-row"><span class="status-label">API ANTAQ</span><span class="status-val lf-ok">● ATIVO</span></div>
            <div class="status-row"><span class="status-label">Modelo LSTM</span><span class="status-val lf-ok">● ATIVO</span></div>
            <div class="status-row"><span class="status-label">PlanetScope</span><span class="status-val lf-ok">● ATIVO</span></div>
          </div>
          <div class="chat-side-title" style="margin-top:8px;">MÉTRICAS LIVE</div>
          <div class="status-block">
            <div class="status-row"><span class="status-label">Polígonos ativos</span><span class="status-val" id="cs-poly" style="color:var(--accent)">14.832</span></div>
            <div class="status-row"><span class="status-label">NDVI atual</span><span class="status-val" id="cs-ndvi" style="color:var(--accent)">0.610</span></div>
            <div class="status-row"><span class="status-label">Umidade solo</span><span class="status-val" id="cs-hum" style="color:var(--warn)">34.0%</span></div>
            <div class="status-row"><span class="status-label">Temp. MATOPIBA</span><span class="status-val" id="cs-temp" style="color:var(--danger)">36.2°C</span></div>
            <div class="status-row"><span class="status-label">Veíc/dia BR-163</span><span class="status-val" id="cs-trucks" style="color:var(--danger)">3.240</span></div>
          </div>
        </div>
      </div>
    </div>

  </div><!-- /main -->
</div><!-- /app -->

<script>
// ═══════════════════════════════════════════════════════════════════
// CLOCK
// ═══════════════════════════════════════════════════════════════════
function updateClock() {
  const now = new Date();
  document.getElementById('clock').textContent =
    now.toLocaleDateString('pt-BR') + ' ' + now.toLocaleTimeString('pt-BR');
  document.getElementById('map-time').textContent = now.toLocaleTimeString('pt-BR');
  // alert timestamps
  ['at-1','at-2','at-3','at-4'].forEach((id,i) => {
    const d = new Date(now.getTime() - (i * 7 + 2) * 60000);
    document.getElementById(id).textContent = 'Detectado às ' + d.toLocaleTimeString('pt-BR');
  });
}
setInterval(updateClock, 1000);
updateClock();

// ═══════════════════════════════════════════════════════════════════
// NAVIGATION
// ═══════════════════════════════════════════════════════════════════
function showPanel(id) {
  document.querySelectorAll('.panel').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('.nav-btn').forEach(b => b.classList.remove('active'));
  document.getElementById('panel-' + id).classList.add('active');
  const idx = {overview:0, map:1, logistica:2, oferta:3, municipal:4, macropolos:5, chat:6};
  const btns = document.querySelectorAll('.nav-btn');
  if (idx[id] !== undefined) btns[idx[id]].classList.add('active');
  if (id === 'map' && !window._mapInit) initMap();
  if (id === 'logistica' && !window._sankeyInit) { initSankey(); updateArbitragem(); updateEcoScore(); updateAIS(); }
  if (id === 'oferta' && !window._ofertaInit) { initOferta(); initCeasaTerminal(); }
  if (id === 'municipal' && !window._munInit) initMunicipal();
  if (id === 'macropolos' && !window._macroInit) initMacroPolos();
}

let sidebarExpanded = false;
function toggleSidebar() {
  sidebarExpanded = !sidebarExpanded;
  document.getElementById('sidebar').classList.toggle('expanded', sidebarExpanded);
  document.getElementById('sb-icon').textContent = sidebarExpanded ? '«' : '»';
}

// ═══════════════════════════════════════════════════════════════════
// SPARKLINE HELPER
// ═══════════════════════════════════════════════════════════════════
function initSparkline(canvasId, data, color) {
  const ctx = document.getElementById(canvasId).getContext('2d');
  return new Chart(ctx, {
    type: 'line',
    data: { labels: data.map((_,i) => i), datasets: [{ data, borderColor: color, borderWidth: 1.5, pointRadius: 0, tension: 0.4, fill: true, backgroundColor: color + '22' }] },
    options: { responsive: false, animation: false, plugins: { legend: { display: false }, tooltip: { enabled: false } }, scales: { x: { display: false }, y: { display: false } } }
  });
}

// init sparklines
const sparkData = {
  soja:  Array.from({length:30}, (_,i) => 147.2 + Math.sin(i*.4)*.5 + (Math.random()-.5)*.3),
  milho: Array.from({length:30}, (_,i) => 89.5  + Math.sin(i*.3)*.4 + (Math.random()-.5)*.3),
  ndvi:  Array.from({length:30}, (_,i) => 0.61  + Math.sin(i*.2)*.02 + (Math.random()-.5)*.005),
  hum:   Array.from({length:30}, (_,i) => 34.0  - i*.05 + (Math.random()-.5)*.3),
  boi:   Array.from({length:30}, (_,i) => 11.2  + Math.sin(i*.3)*.2 + (Math.random()-.5)*.1),
  horti: Array.from({length:30}, (_,i) => 38.4  - Math.sin(i*.5)*.4 + (Math.random()-.5)*.2),
};
const sparks = {
  soja:  initSparkline('sp-soja',  sparkData.soja,  '#00d4ff'),
  milho: initSparkline('sp-milho', sparkData.milho, '#ffc107'),
  ndvi:  initSparkline('sp-ndvi',  sparkData.ndvi,  '#00ff88'),
  hum:   initSparkline('sp-hum',   sparkData.hum,   '#00d4ff'),
  boi:   initSparkline('sp-boi',   sparkData.boi,   '#00ff88'),
  horti: initSparkline('sp-horti', sparkData.horti, '#ff6b35'),
};

function pushSparkline(chart, dataArr, newVal) {
  dataArr.shift();
  dataArr.push(newVal);
  chart.data.datasets[0].data = [...dataArr];
  chart.update('none');
}

// ═══════════════════════════════════════════════════════════════════
// NDVI LIVE CHART
// ═══════════════════════════════════════════════════════════════════
const NDVI_MAX_PTS = 60;
const ndviData = {
  cerrado: Array.from({length:NDVI_MAX_PTS}, (_,i) => +(0.62 + 0.06*Math.sin(i*.08) + (Math.random()-.5)*.02).toFixed(3)),
  matopiba: Array.from({length:NDVI_MAX_PTS}, (_,i) => +(0.40 + 0.07*Math.sin((i+10)*.08) + (Math.random()-.5)*.03).toFixed(3)),
  pr_ms:   Array.from({length:NDVI_MAX_PTS}, (_,i) => +(0.58 + 0.05*Math.sin((i+20)*.08) + (Math.random()-.5)*.02).toFixed(3)),
  pampa:   Array.from({length:NDVI_MAX_PTS}, (_,i) => +(0.55 + 0.04*Math.sin((i+5)*.08)  + (Math.random()-.5)*.02).toFixed(3)),
};
const ndviLabels = Array.from({length:NDVI_MAX_PTS}, (_,i) => '-' + (NDVI_MAX_PTS - 1 - i) + 's');

const ndviCtx = document.getElementById('chartNdvi').getContext('2d');
const ndviChart = new Chart(ndviCtx, {
  type: 'line',
  data: {
    labels: [...ndviLabels],
    datasets: [
      { label: 'Cerrado (MT/GO)', data: [...ndviData.cerrado], borderColor: '#00d4ff', borderWidth: 1.5, pointRadius: 0, tension: 0.4 },
      { label: 'MATOPIBA (BA/PI)', data: [...ndviData.matopiba], borderColor: '#ff3d3d', borderWidth: 1.5, pointRadius: 0, tension: 0.4 },
      { label: 'Norte PR / Sul MS', data: [...ndviData.pr_ms], borderColor: '#ffc107', borderWidth: 1.5, pointRadius: 0, tension: 0.4 },
      { label: 'Pampa (RS/AR)', data: [...ndviData.pampa], borderColor: '#00ff88', borderWidth: 1.5, pointRadius: 0, tension: 0.4 },
    ]
  },
  options: {
    responsive: true, maintainAspectRatio: false, animation: false,
    interaction: { mode: 'index', intersect: false },
    plugins: { legend: { labels: { color: '#6a92b0', font: { family: 'Courier New', size: 10 }, boxWidth: 16 } },
      tooltip: { backgroundColor: '#0d1f33', borderColor: '#0e2d4a', borderWidth: 1, titleColor: '#00d4ff', bodyColor: '#c8dff0', titleFont: { family: 'Courier New' }, bodyFont: { family: 'Courier New', size: 11 } }
    },
    scales: {
      x: { ticks: { color: '#6a92b0', font: { family: 'Courier New', size: 9 }, maxTicksLimit: 10 }, grid: { color: '#0e2d4a' } },
      y: { min: 0.25, max: 0.80, ticks: { color: '#6a92b0', font: { family: 'Courier New', size: 10 } }, grid: { color: '#0e2d4a' } }
    }
  }
});

function pushNdviPoint() {
  const t = Date.now() / 1000;
  const nC  = +(0.61 + 0.06*Math.sin(t*.03) + (Math.random()-.5)*.015).toFixed(3);
  const nM  = +(0.38 + 0.08*Math.sin(t*.03+1) + (Math.random()-.5)*.02).toFixed(3);
  const nP  = +(0.57 + 0.05*Math.sin(t*.03+2) + (Math.random()-.5)*.015).toFixed(3);
  const nPa = +(0.55 + 0.04*Math.sin(t*.03+3) + (Math.random()-.5)*.015).toFixed(3);
  [ndviData.cerrado, ndviData.matopiba, ndviData.pr_ms, ndviData.pampa].forEach(arr => arr.shift());
  ndviData.cerrado.push(nC); ndviData.matopiba.push(nM); ndviData.pr_ms.push(nP); ndviData.pampa.push(nPa);
  ndviChart.data.datasets[0].data = [...ndviData.cerrado];
  ndviChart.data.datasets[1].data = [...ndviData.matopiba];
  ndviChart.data.datasets[2].data = [...ndviData.pr_ms];
  ndviChart.data.datasets[3].data = [...ndviData.pampa];
  ndviChart.update('none');
  // update topbar NDVI
  setLiveVal('ts-ndvi', nC.toFixed(3), 0.61, 0.001);
  setLiveVal('cs-ndvi', nC.toFixed(3), 0.61, 0.001);
}
setInterval(pushNdviPoint, 3000);

// ═══════════════════════════════════════════════════════════════════
// LIVE VALUE UPDATER
// ═══════════════════════════════════════════════════════════════════
function setLiveVal(id, val, prevVal, threshold) {
  const el = document.getElementById(id);
  if (!el) return;
  el.textContent = val;
  el.classList.remove('val-flash');
  void el.offsetWidth;
  if (Math.abs(parseFloat(val) - prevVal) > threshold) el.classList.add('val-flash');
}

// ═══════════════════════════════════════════════════════════════════
// WEATHER LIVE UPDATE
// ═══════════════════════════════════════════════════════════════════
const wxBase = [
  { t: 36.2, h: 18, w: 14 },
  { t: 33.8, h: 31, w: 9  },
  { t: 28.4, h: 68, w: 11 },
  { t: 30.1, h: 52, w: 7  },
  { t: 22.7, h: 61, w: 18 },
  { t: 31.5, h: 84, w: 5  },
];
function updateWeather() {
  wxBase.forEach((b, i) => {
    const n = i + 1;
    const t = +(b.t + (Math.random()-.5)*.4).toFixed(1);
    const h = Math.round(b.h + (Math.random()-.5)*2);
    const w = Math.round(b.w + (Math.random()-.5)*2);
    document.getElementById('wx-t'+n).textContent = t + '°C';
    document.getElementById('wx-h'+n).textContent = 'Umid: ' + h + '%';
    document.getElementById('wx-w'+n).textContent = 'Vento: ' + w + 'km/h';
    b.t = t; b.h = h; b.w = w;
  });
  // also update topbar temp
  const mt = wxBase[0].t;
  setLiveVal('ts-temp', mt.toFixed(1) + '°C', 36.2, 0.3);
  setLiveVal('cs-temp', mt.toFixed(1) + '°C', 36.2, 0.3);
}
setInterval(updateWeather, 5000);

// ═══════════════════════════════════════════════════════════════════
// LOGISTICS LIVE UPDATE
// ═══════════════════════════════════════════════════════════════════
const logState = { br163: 82, santos: 74, par: 71, ferro: 61, ros: 48, br364: 55 };
function updateLogistics() {
  const jitter = () => (Math.random()-.5)*1.2;
  const clamp = (v,mn,mx) => Math.min(mx, Math.max(mn, v));
  logState.br163  = clamp(logState.br163  + jitter(), 78, 88);
  logState.santos = clamp(logState.santos + jitter(), 70, 80);
  logState.par    = clamp(logState.par    + jitter(), 67, 76);
  logState.ferro  = clamp(logState.ferro  + jitter(), 57, 66);
  logState.ros    = clamp(logState.ros    + jitter(), 44, 53);
  logState.br364  = clamp(logState.br364  + jitter(), 51, 60);

  const update = (key, color) => {
    const v = Math.round(logState[key]);
    const pf = document.getElementById('pf-' + key);
    const cv = document.getElementById('cv-' + key);
    if (pf) { pf.style.width = v + '%'; pf.style.background = color; }
    if (cv) { cv.textContent = v + '%'; cv.style.color = color; }
  };
  const c163 = logState.br163 > 85 ? '#ff3d3d' : logState.br163 > 78 ? '#ffc107' : '#00ff88';
  update('br163', c163);
  update('santos', logState.santos > 78 ? '#ff3d3d' : '#ffc107');
  update('par', logState.par > 75 ? '#ffc107' : '#00ff88');
  update('ferro', '#00ff88'); update('ros', '#00ff88'); update('br364', '#00ff88');

  // trucks counter
  const trucks = Math.round(3240 + (Math.random()-.5)*80);
  setLiveVal('ts-trucks', trucks.toLocaleString('pt-BR'), 3240, 30);
  setLiveVal('cs-trucks', trucks.toLocaleString('pt-BR'), 3240, 30);
  const rd = document.getElementById('rd-br163-flow');
  if (rd) rd.textContent = 'Fluxo: ' + trucks.toLocaleString('pt-BR') + ' veíc/dia';

  // header badges
  const ph163 = document.getElementById('ph-br163');
  if (ph163) ph163.textContent = 'BR-163: ' + Math.round(logState.br163) + '%';
  const phs = document.getElementById('ph-santos');
  if (phs) phs.textContent = 'SANTOS: ' + Math.round(logState.santos) + '%';

  // update sankey chart if visible
  if (window._sankeyChart) {
    window._sankeyChart.data.datasets[0].data = [
      +(18.4 + (Math.random()-.5)*.3).toFixed(2),
      +(15.2 + (Math.random()-.5)*.2).toFixed(2),
      +(6.8  + (Math.random()-.5)*.15).toFixed(2),
      +(9.6  + (Math.random()-.5)*.2).toFixed(2),
      +(8.1  + (Math.random()-.5)*.15).toFixed(2),
      +(5.4  + (Math.random()-.5)*.12).toFixed(2),
      +(13.5 + (Math.random()-.5)*.2).toFixed(2),
    ];
    window._sankeyChart.update('none');
  }
  updateLogKpis();
}
setInterval(updateLogistics, 4000);

// ═══════════════════════════════════════════════════════════════════
// LOGISTICS KPIs: Custo Brasil + IEL + ETA Cards + Rerouting
// ═══════════════════════════════════════════════════════════════════
function updateLogKpis() {
  const satAvg = (logState.br163 + logState.santos + logState.par) / 3;
  const baseLoss = 1800000;
  const penalty = Math.max(0, satAvg - 65) * 44000;
  const custo = baseLoss + penalty + (Math.random() - 0.5) * 120000;
  const iel = Math.max(22, Math.min(94, Math.round(100 - (satAvg - 40) * 1.15 + (Math.random() - 0.5) * 2)));

  const custoEl = document.getElementById('log-custo-val');
  if (custoEl) custoEl.textContent = 'R$ ' + Math.round(custo).toLocaleString('pt-BR');
  const ielEl = document.getElementById('iel-val');
  if (ielEl) { ielEl.textContent = iel + '/100'; ielEl.style.color = iel >= 70 ? '#00ff88' : iel >= 50 ? '#ffc107' : '#ff3d3d'; }
  const ielBar = document.getElementById('iel-bar');
  if (ielBar) ielBar.style.width = iel + '%';
  const phIel = document.getElementById('ph-iel');
  if (phIel) { phIel.textContent = 'IEL: ' + iel; phIel.style.color = iel >= 70 ? '#00ff88' : iel >= 50 ? '#ffc107' : '#ff3d3d'; }

  buildEtaCards();
}

function buildEtaCards() {
  const container = document.getElementById('eta-cards');
  if (!container) return;
  const routes = [
    { name:'Sorriso (MT) → Porto Santos', corridor:'BR-163', baseTh:72, satKey:'br163', delayFactor:0.22 },
    { name:'Rio Verde (GO) → Paranaguá', corridor:'Ferroviário RUMO', baseTh:48, satKey:'ferro', delayFactor:0.10 },
    { name:'Cascavel (PR) → Paranaguá', corridor:'Malha SP/Sul', baseTh:24, satKey:'par', delayFactor:0.14 },
    { name:'Hernandarias (PY) → Rosário', corridor:'Hidrovia Paraguai', baseTh:96, satKey:'ros', delayFactor:0.06 },
  ];
  container.innerHTML = routes.map(r => {
    const sat = logState[r.satKey] || 60;
    const delayH = Math.round(Math.max(0, sat - 65) * r.delayFactor);
    const eta = r.baseTh + delayH;
    const col = sat >= 82 ? 'var(--danger)' : sat >= 70 ? 'var(--warn)' : 'var(--accent2)';
    const delayStr = delayH > 0
      ? `<span style="color:var(--danger)">+${delayH}h atraso previsto</span>`
      : `<span style="color:var(--accent2)">no prazo</span>`;
    return `<div style="background:var(--bg3);border-left:2px solid ${col};padding:5px 8px;border-radius:2px;">
      <div style="font-size:9px;color:var(--text2);margin-bottom:2px;">${r.name}</div>
      <div style="display:flex;justify-content:space-between;align-items:center;">
        <span style="font-size:11px;">ETA: <b style="color:${col};">${eta}h</b></span>
        <span style="font-size:9px;">${delayStr}</span>
      </div>
      <div style="font-size:9px;color:var(--text2);margin-top:1px;">${r.corridor} · Sat. <span style="color:${col};">${Math.round(sat)}%</span></div>
    </div>`;
  }).join('');
}

function applyReroute() {
  const btn = document.getElementById('reroute-btn');
  const status = document.getElementById('reroute-status');
  const msg = document.getElementById('reroute-msg');
  if (!btn) return;
  btn.disabled = true;
  btn.textContent = '⟳ IA PROCESSANDO...';
  if (status) status.textContent = 'Recalculando malha logística...';
  setTimeout(() => {
    logState.br163 = Math.max(70, logState.br163 - 9);
    logState.ferro = Math.min(88, logState.ferro + 7);
    btn.textContent = '✓ ROTEAMENTO APLICADO';
    if (status) status.textContent = '';
    if (msg) msg.innerHTML = 'Re-roteamento executado com sucesso. 20% do fluxo BR-163 desviado para Ferrovia Norte-Sul. <span style="color:#00ff88;font-weight:bold;">Economia: R$ 1,2M · ETA -6h</span>';
    setTimeout(() => {
      btn.disabled = false;
      btn.textContent = '⚡ RE-ROTEAR VIA IA';
      if (msg) msg.innerHTML = 'A IA sugere desviar 20% do fluxo BR-163 para a Ferrovia Norte-Sul. Economia estimada: <span style="color:#00ff88;font-weight:bold;">R$ 1,2M</span> e <span style="color:#00ff88;font-weight:bold;">-6h</span> de ETA.';
    }, 18000);
  }, 1800);
}

// ═══════════════════════════════════════════════════════════════════
// PRICE TICKER LIVE
// ═══════════════════════════════════════════════════════════════════
const prices = {
  soja:    { val: 10.42, unit: 'US$/bu', dir: -1 },
  milho:   { val: 4.68,  unit: 'US$/bu', dir: 1  },
  boi:     { val: 312.4, unit: 'R$/@',   dir: 1  },
  acucar:  { val: 19.85, unit: 'US$/lb', dir: -1 },
  cafe:    { val: 218.6, unit: 'US$/sc', dir: 1  },
  algodao: { val: 72.3,  unit: 'US$/lb', dir: -1 },
  usd:     { val: 5.124, unit: 'R$',     dir: 1  },
  tomate:  { val: 68.2,  unit: 'R$/cx',  dir: 1  },
};
const tickerIds = { soja:'tp-soja', milho:'tp-milho', boi:'tp-boi', acucar:'tp-acucar', cafe:'tp-cafe', algodao:'tp-algodao', usd:'tp-usd', tomate:'tp-tomate' };
function updatePrices() {
  for (const [key, p] of Object.entries(prices)) {
    const change = (Math.random()-.48) * 0.12;
    p.val = Math.max(0.1, p.val + change);
    p.dir = change > 0 ? 1 : -1;
    const el = document.getElementById(tickerIds[key]);
    if (!el) continue;
    const fmt = p.val > 100 ? p.val.toFixed(1) : p.val.toFixed(2);
    const arrow = p.dir > 0 ? ' ▲' : ' ▼';
    el.textContent = p.unit + ' ' + fmt + arrow;
    el.className = 'tick-val ' + (p.dir > 0 ? 'tick-up' : 'tick-dn');
  }
}
setInterval(updatePrices, 3500);

// ═══════════════════════════════════════════════════════════════════
// SATELLITE COUNTDOWN
// ═══════════════════════════════════════════════════════════════════
let satSeconds = { s2a: 42*60, ps: 75*60 };
function updateSatellite() {
  satSeconds.s2a = Math.max(0, satSeconds.s2a - 4);
  satSeconds.ps  = Math.max(0, satSeconds.ps  - 4);
  if (satSeconds.s2a === 0) satSeconds.s2a = 95 * 60;
  if (satSeconds.ps  === 0) satSeconds.ps  = 98 * 60;

  const fmt = s => { const m = Math.floor(s/60), sec = s%60; return String(m).padStart(2,'0') + ':' + String(sec).padStart(2,'0'); };
  const el1 = document.getElementById('ms-s2a'); if (el1) el1.textContent = 'Passando em ' + fmt(satSeconds.s2a);
  const el2 = document.getElementById('ms-ps');  if (el2) el2.textContent = 'Passando em ' + fmt(satSeconds.ps);
  const pct1 = (1 - satSeconds.s2a / (95*60)) * 100;
  const pct2 = (1 - satSeconds.ps  / (98*60)) * 100;
  const sf1 = document.getElementById('sf-s2a'); if (sf1) sf1.style.width = pct1 + '%';
  const sf2 = document.getElementById('sf-ps');  if (sf2) sf2.style.width = pct2 + '%';

  // topbar countdown
  const m = Math.floor(satSeconds.s2a / 60), s = satSeconds.s2a % 60;
  setLiveVal('ts-orbit', String(m).padStart(2,'0') + ':' + String(s).padStart(2,'0'), 0, 9999);

  // map polygon count fluctuation
  const poly = Math.round(14832 + (Math.random()-.5)*20);
  const pEl = document.getElementById('map-poly'); if (pEl) pEl.textContent = poly.toLocaleString('pt-BR');
  const csEl = document.getElementById('cs-poly'); if (csEl) csEl.textContent = poly.toLocaleString('pt-BR');
}
setInterval(updateSatellite, 4000);
updateSatellite();

// ═══════════════════════════════════════════════════════════════════
// HUMIDITY + SPARKLINE LIVE
// ═══════════════════════════════════════════════════════════════════
let liveHum = 34.0;
function updateHumidity() {
  liveHum = Math.max(28, Math.min(40, liveHum + (Math.random()-.52)*.15));
  const v = liveHum.toFixed(1);
  setLiveVal('ts-hum', v + '%', 34.0, 0.1);
  setLiveVal('cs-hum', v + '%', 34.0, 0.1);
  pushSparkline(sparks.hum, sparkData.hum, liveHum);
  pushSparkline(sparks.ndvi, sparkData.ndvi, ndviData.cerrado[ndviData.cerrado.length-1]);
}
setInterval(updateHumidity, 5000);

// ═══════════════════════════════════════════════════════════════════
// OFERTA TABLE LIVE FLUCTUATION
// ═══════════════════════════════════════════════════════════════════
const ofertaBase = {
  soja:147.2, milho:89.5, cana:610.0, algodao:3.1, arroz:12.3, feijao:3.4,
  'tomate-mesa':5.1, 'tomate-ind':4.7, pimentao:3.2, folh:4.1, citr:24.5,
  batata:4.8, cebola:1.6, morango:0.4, maca:1.1, melao:0.6,
  banana:7.3, mamao:1.8, alho:0.2, cenoura:0.8, pepino:0.5,
  abacaxi:2.6, uva:1.7, manga:1.4,
  'uva-ar':3.1, 'maca-ar':0.9,
  boi:11.2, frango:14.6, suino:5.2
};
function updateOfertaTable() {
  for (const [key, base] of Object.entries(ofertaBase)) {
    const jitter = (Math.random()-.5) * base * 0.002;
    ofertaBase[key] = Math.max(base * 0.97, Math.min(base * 1.03, ofertaBase[key] + jitter));
    const el = document.getElementById('ot-' + key);
    if (!el) continue;
    el.textContent = ofertaBase[key].toFixed(1);
  }
  if (window._ofertaChart) {
    window._ofertaChart.data.datasets[1].data = window._ofertaChart.data.datasets[1].data.map(
      (v, i) => +(v + (Math.random()-.5) * (i < 3 ? 0.3 : 0.15)).toFixed(2)
    );
    window._ofertaChart.update('none');
  }
}
setInterval(updateOfertaTable, 6000);

